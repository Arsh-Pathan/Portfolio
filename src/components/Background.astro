<canvas id="background"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("background") as HTMLCanvasElement;

  if (canvas) {
    const scene = new THREE.Scene();
    // Removed Fog to keep pure black/white visibility throughout the journey

    const camera = new THREE.PerspectiveCamera(
      75,
      window.innerWidth / window.innerHeight,
      1,
      8000
    );

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // ----------------------------------------------------
    // TEXTURE GENERATORS (No more square boxes)
    // ----------------------------------------------------
    const createCircleTexture = (glow = false) => {
       const texCanvas = document.createElement('canvas');
       texCanvas.width = 64;
       texCanvas.height = 64;
       const ctx = texCanvas.getContext('2d');
       if(glow) {
           const gradient = ctx!.createRadialGradient(32, 32, 0, 32, 32, 32);
           gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
           gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
           ctx!.fillStyle = gradient;
           ctx!.fillRect(0, 0, 64, 64);
       } else {
           ctx!.beginPath();
           ctx!.arc(32, 32, 30, 0, 2 * Math.PI);
           ctx!.fillStyle = 'white';
           ctx!.fill();
       }
       return new THREE.CanvasTexture(texCanvas);
    };
    
    const createMathTexture = (text: string) => {
       const texCanvas = document.createElement('canvas');
       texCanvas.width = 512; // Wider to fit equations
       texCanvas.height = 128;
       const ctx = texCanvas.getContext('2d');
       ctx!.fillStyle = 'rgba(255, 255, 255, 0)';
       ctx!.fillRect(0, 0, 512, 128);
       ctx!.font = 'bold 48px serif';
       ctx!.fillStyle = 'rgba(255, 255, 255, 0.8)';
       ctx!.textAlign = 'center';
       ctx!.textBaseline = 'middle';
       ctx!.fillText(text, 256, 64);
       return new THREE.CanvasTexture(texCanvas);
    };
    
    const createRingTexture = () => {
       const texCanvas = document.createElement('canvas');
       texCanvas.width = 64;
       texCanvas.height = 64;
       const ctx = texCanvas.getContext('2d');
       ctx!.beginPath();
       ctx!.arc(32, 32, 28, 0, 2 * Math.PI);
       ctx!.strokeStyle = 'white';
       ctx!.lineWidth = 4;
       ctx!.stroke();
       return new THREE.CanvasTexture(texCanvas);
    };
    
    const circleTex = createCircleTexture(false);
    const glowTex = createCircleTexture(true);
    const ringTex = createRingTexture();

    // ----------------------------------------------------
    // PATH HELPER
    // ----------------------------------------------------
    function getPathPoint(progress: number) {
       const z = 1200 - progress * 5700;
       const rads = progress * Math.PI * 2;
       const x = Math.sin(rads * 1.5) * 1000;
       const y = Math.cos(rads * 1.2) * 800;
       return new THREE.Vector3(x, y, z);
    }

    // Array to hold all major scene objects for distance fading
    const sceneElements: any[] = [];
    const updatables: any[] = []; // for animations

    // ----------------------------------------------------
    // ZONE 1: FLOATING STRUCTURED NEURAL NETWORKS
    // ----------------------------------------------------
    function createStructuredNN(progress: number, offset: THREE.Vector3, is3D: boolean = false) {
       const center = getPathPoint(progress).add(offset);
       const group = new THREE.Group();
       
       const posArray: number[] = [];
       const linePosArray: number[] = [];
       
       if (!is3D) {
           const variant = Math.floor(Math.random() * 3);
           
           if (variant === 0) {
               // Classic Layered
               const layers = [4, 7, 10, 7, 4]; 
               const layerSpacing = 35;
               const nodeSpacing = 25;
               for(let l=0; l<layers.length; l++) {
                   for(let n=0; n<layers[l]; n++) {
                       posArray.push(
                           (l - layers.length/2) * layerSpacing,
                           (n - layers[l]/2) * nodeSpacing,
                           0
                       );
                   }
               }
               let offsetIdx = 0;
               for(let l=0; l<layers.length-1; l++) {
                   const currentLayerNodes = layers[l];
                   const nextLayerNodes = layers[l+1];
                   for(let i=0; i<currentLayerNodes; i++) {
                       for(let j=0; j<nextLayerNodes; j++) {
                           if(Math.random() > 0.3) {
                               const idx1 = offsetIdx + i;
                               const idx2 = offsetIdx + currentLayerNodes + j;
                               linePosArray.push(posArray[idx1*3], posArray[idx1*3+1], posArray[idx1*3+2]);
                               linePosArray.push(posArray[idx2*3], posArray[idx2*3+1], posArray[idx2*3+2]);
                           }
                       }
                   }
                   offsetIdx += currentLayerNodes;
               }
           } else if (variant === 1) {
               // Grid / Matrix (CNN-like)
               const sizeX = 7;
               const sizeY = 7;
               const spacing = 22;
               for(let x=0; x<sizeX; x++) {
                   for(let y=0; y<sizeY; y++) {
                       posArray.push((x - sizeX/2)*spacing, (y - sizeY/2)*spacing, 0);
                   }
               }
               for(let x=0; x<sizeX; x++) {
                   for(let y=0; y<sizeY; y++) {
                       const idx = x * sizeY + y;
                       if(x < sizeX - 1) {
                           const rightIdx = (x+1)*sizeY + y;
                           linePosArray.push(posArray[idx*3], posArray[idx*3+1], posArray[idx*3+2]);
                           linePosArray.push(posArray[rightIdx*3], posArray[rightIdx*3+1], posArray[rightIdx*3+2]);
                       }
                       if(y < sizeY - 1) {
                           const downIdx = x*sizeY + (y+1);
                           linePosArray.push(posArray[idx*3], posArray[idx*3+1], posArray[idx*3+2]);
                           linePosArray.push(posArray[downIdx*3], posArray[downIdx*3+1], posArray[downIdx*3+2]);
                       }
                   }
               }
           } else {
               // Radial / Star topology
               const rings = [1, 6, 12, 18];
               for(let r=0; r<rings.length; r++) {
                   const nodesInRing = rings[r];
                   const radius = r * 25;
                   for(let i=0; i<nodesInRing; i++) {
                       const angle = (Math.PI * 2 * i) / nodesInRing;
                       posArray.push( Math.cos(angle)*radius, Math.sin(angle)*radius, 0 );
                   }
               }
               const count = posArray.length / 3;
               for(let i=0; i<count; i++) {
                   for(let j=i+1; j<count; j++) {
                       const dx = posArray[i*3] - posArray[j*3];
                       const dy = posArray[i*3+1] - posArray[j*3+1];
                       if (dx*dx + dy*dy < 32*32) {
                           if(Math.random() > 0.2) {
                               linePosArray.push(posArray[i*3], posArray[i*3+1], posArray[i*3+2]);
                               linePosArray.push(posArray[j*3], posArray[j*3+1], posArray[j*3+2]);
                           }
                       }
                   }
               }
           }
       } else {
           // 3D CLUSTER STRUCTURE: Concentric Spheres
           const layers3D = [4, 12, 24];
           const radius3D = [30, 80, 140];
           
           for(let l=0; l<layers3D.length; l++) {
               const nodes = layers3D[l];
               const r = radius3D[l];
               for(let i=0; i<nodes; i++) {
                   const phi = Math.acos(1 - 2 * (i + 0.5) / nodes);
                   const theta = Math.PI * (1 + Math.sqrt(5)) * (i + 0.5);
                   posArray.push(
                       r * Math.cos(theta) * Math.sin(phi),
                       r * Math.sin(theta) * Math.sin(phi),
                       r * Math.cos(phi)
                   );
               }
           }
           const count = posArray.length / 3;
           for(let i=0; i<count; i++) {
               for(let j=i+1; j<count; j++) {
                   const dx = posArray[i*3] - posArray[j*3];
                   const dy = posArray[i*3+1] - posArray[j*3+1];
                   const dz = posArray[i*3+2] - posArray[j*3+2];
                   if (dx*dx + dy*dy + dz*dz < 100*100) {
                       linePosArray.push(posArray[i*3], posArray[i*3+1], posArray[i*3+2]);
                       linePosArray.push(posArray[j*3], posArray[j*3+1], posArray[j*3+2]);
                   }
               }
           }
       }
       
       const nodeCount = posArray.length / 3;
       const pos = new Float32Array(posArray);
       const nodeGeo = new THREE.BufferGeometry();
       nodeGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
       
       // Inner Dot (Fainter, Constant)
       const innerMat = new THREE.PointsMaterial({ 
           map: circleTex, size: 6, color: 0x666666, transparent: true, opacity: 0.5, depthWrite: false, blending: THREE.AdditiveBlending 
       });
       const innerMesh = new THREE.Points(nodeGeo, innerMat);
       group.add(innerMesh);
       
       // Outer Node (Brighter, Flashing rapidly)
       const nodeColors = new Float32Array(nodeCount * 3);
       const outerGeo = new THREE.BufferGeometry();
       outerGeo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
       outerGeo.setAttribute('color', new THREE.BufferAttribute(nodeColors, 3));
       const outerMat = new THREE.PointsMaterial({ 
           map: circleTex, size: 16, vertexColors: true, transparent: true, opacity: 1.0, depthWrite: false, blending: THREE.AdditiveBlending 
       });
       const outerMesh = new THREE.Points(outerGeo, outerMat);
       group.add(outerMesh);
       
       // Lines between layers/nodes
       const lineCount = linePosArray.length / 6;
       const lineColors = new Float32Array(lineCount * 6);
       const lineGeo = new THREE.BufferGeometry();
       lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(linePosArray, 3));
       lineGeo.setAttribute('color', new THREE.BufferAttribute(lineColors, 3));
       const lineMat = new THREE.LineBasicMaterial({ vertexColors: true, transparent: true, opacity: 0.8, depthWrite: false, blending: THREE.AdditiveBlending });
       const linesMesh = new THREE.LineSegments(lineGeo, lineMat);
       group.add(linesMesh);
       
       const nodeActivations = new Float32Array(nodeCount);
       const lineActivations = new Float32Array(lineCount);
       
       group.position.copy(center);
       group.rotation.set(Math.random()*0.5, Math.random()*0.5, Math.random()*0.5);
       scene.add(group);
       
       const timeOffset = Math.random() * 100;
       
       sceneElements.push({
           group,
           center,
           updateFade: (camPos: THREE.Vector3) => {
               const dist = camPos.distanceTo(center);
               let fade = 0;
               if (dist < 2000) {
                   fade = 1.0 - Math.max(0, (dist - 400) / 1600);
               }
               innerMat.opacity = 0.2 * fade;
               outerMat.opacity = 0.5 * fade;
               lineMat.opacity = 0.35 * fade;
           },
           update: (time: number) => {
               const t = time + timeOffset;
               group.position.x = center.x + Math.sin(t * 0.4) * 30;
               group.position.y = center.y + Math.cos(t * 0.3) * 30;
               group.position.z = center.z + Math.sin(t * 0.2) * 30;
               
               const nColors = outerMesh.geometry.attributes.color.array as Float32Array;
               const lColors = linesMesh.geometry.attributes.color.array as Float32Array;
               
               if (Math.random() < 0.8) {
                   const rNode = Math.floor(Math.random() * nodeCount);
                   nodeActivations[rNode] = 1.0;
               }
               
               for(let i=0; i<2; i++) {
                   const rLine = Math.floor(Math.random() * lineCount);
                   lineActivations[rLine] = 1.0;
               }
               
               for(let i=0; i<nodeCount; i++) {
                   nodeActivations[i] = Math.max(0, nodeActivations[i] - 0.15); 
                   const v = 0.3 + nodeActivations[i] * 0.7; 
                   nColors[i*3] = v;
                   nColors[i*3+1] = v;
                   nColors[i*3+2] = v;
               }
               
               for(let i=0; i<lineCount; i++) {
                   lineActivations[i] = Math.max(0, lineActivations[i] - 0.20); 
                   const v = 0.2 + lineActivations[i] * 0.8; 
                   lColors[i*6] = v;
                   lColors[i*6+1] = v;
                   lColors[i*6+2] = v;
                   lColors[i*6+3] = v;
                   lColors[i*6+4] = v;
                   lColors[i*6+5] = v;
               }
               
               outerMesh.geometry.attributes.color.needsUpdate = true;
               linesMesh.geometry.attributes.color.needsUpdate = true;
           }
       });
    }
    
    // Repositioned Neural Networks (No early ones to protect Hero section)
    createStructuredNN(0.32, new THREE.Vector3(350, 150, -50), false); // 2D 
    createStructuredNN(0.45, new THREE.Vector3(-450, 100, 150), true); // 3D
    createStructuredNN(0.55, new THREE.Vector3(-300, -200, 100), false); // 2D
    createStructuredNN(0.68, new THREE.Vector3(350, -250, -50), false); // 2D
    createStructuredNN(0.80, new THREE.Vector3(450, -150, -100), true); // 3D
    createStructuredNN(0.92, new THREE.Vector3(-350, 250, 50), false); // 2D

    // ----------------------------------------------------
    // ZONE 2: NANOPARTICLE WORMS
    // ----------------------------------------------------
    function createWorm(progress: number, offset: THREE.Vector3) {
        const center = getPathPoint(progress).add(offset);
        const spineLength = 60;
        const particlesPerSegment = 10;
        const totalParticles = spineLength * particlesPerSegment;
        
        const geo = new THREE.BufferGeometry();
        const pos = new Float32Array(totalParticles * 3);
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        
        const pBaseOpacity = 0.35;
        const mat = new THREE.PointsMaterial({ 
            map: glowTex, 
            size: 10, 
            color: 0xffffff, 
            transparent: true, 
            opacity: pBaseOpacity, 
            depthWrite: false, 
            blending: THREE.AdditiveBlending 
        });
        const pts = new THREE.Points(geo, mat);
        pts.position.copy(center);
        scene.add(pts);
        
        const timeOffset = Math.random() * 100;
        
        sceneElements.push({
           group: pts,
           center,
           updateFade: (camPos: THREE.Vector3) => {
               const dist = camPos.distanceTo(center);
               let fade = 0;
               if (dist < 2500) {
                   fade = 1.0 - Math.max(0, (dist - 600) / 1900);
               }
               mat.opacity = pBaseOpacity * fade;
           },
           update: (time: number) => {
               const positions = pts.geometry.attributes.position.array as Float32Array;
               const tt = time + timeOffset;
               
               for(let s=0; s<spineLength; s++) {
                   const st = tt - s * 0.03;
                   const cx = Math.sin(st * 1.2) * 350;
                   const cy = Math.cos(st * 0.9) * 250;
                   const cz = Math.sin(st * 0.5) * 400;
                   
                   for(let p=0; p<particlesPerSegment; p++) {
                       const idx = (s * particlesPerSegment + p) * 3;
                       const angle = (p / particlesPerSegment) * Math.PI * 2 + st * 3;
                       const radius = 25 + Math.sin(st * 5 + p) * 15; 
                       
                       positions[idx] = cx + Math.cos(angle) * radius;
                       positions[idx+1] = cy + Math.sin(angle) * radius;
                       positions[idx+2] = cz + Math.cos(angle * 0.5) * radius;
                   }
               }
               pts.geometry.attributes.position.needsUpdate = true;
           }
        });
    }
    
    // Placed sequentially along the path
    createWorm(0.1, new THREE.Vector3(-150, 200, 0));
    createWorm(0.35, new THREE.Vector3(250, -150, 0));
    createWorm(0.65, new THREE.Vector3(-250, 100, 0));

    // ----------------------------------------------------
    // ZONE 3: SPIRALING GALAXY (Singularity)
    // ----------------------------------------------------
    function createSingularity(progress: number, offset: THREE.Vector3) {
       const center = getPathPoint(progress).add(offset);
       const count = 5000;
       const geo = new THREE.BufferGeometry();
       const pos = new Float32Array(count * 3);
       
       const arms = 4;
       
       for(let i=0; i<count; i++) {
           // Biased towards the center for a glowing core, but spanning up to 1400
           const radius = Math.pow(Math.random(), 1.5) * 1400; 
           
           // Theta is tied strictly to radius to form tight spiral arms
           const theta = radius * 0.008; 
           
           const armOffset = (i % arms) * (Math.PI * 2 / arms);
           
           // Add noise (spread) that is tight near the core and looser at the edges
           const spread = 15 + (radius * 0.08);
           const noiseX = (Math.random() - 0.5) * spread;
           const noiseZ = (Math.random() - 0.5) * spread;
           
           const x = Math.cos(theta + armOffset) * radius + noiseX;
           
           // Flatten the Y axis heavily to form a disc, with a glowing bulge in the center
           const bulge = Math.max(0, 1 - (radius / 400)) * 150;
           const y = (Math.random() - 0.5) * (spread * 0.3 + bulge); 
           
           const z = Math.sin(theta + armOffset) * radius + noiseZ;
           
           pos[i*3] = x;
           pos[i*3+1] = y;
           pos[i*3+2] = z;
       }
       geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
       
       const pBaseOpacity = 0.5;
       const pMat = new THREE.PointsMaterial({ 
           map: glowTex, 
           size: 8, 
           color: 0xffffff, 
           transparent: true, 
           opacity: pBaseOpacity, 
           depthWrite: false,
           blending: THREE.AdditiveBlending
       });
       
       const pts = new THREE.Points(geo, pMat);
       const group = new THREE.Group();
       group.add(pts);
       group.position.copy(center);
       
       // Randomize the galaxy rotation for variety
       group.rotation.x = Math.PI * (0.2 + Math.random() * 0.3);
       group.rotation.z = Math.PI * (0.1 + Math.random() * 0.4);
       group.rotation.y = Math.random() * Math.PI;
       
       scene.add(group);
       
       sceneElements.push({
           group,
           center,
           updateFade: (camPos: THREE.Vector3) => {
               const dist = camPos.distanceTo(center);
               let fade = 0;
               // Galaxies are huge, they fade in from very far away
               if (dist < 6000) {
                   fade = 1.0 - Math.max(0, (dist - 1500) / 4500);
               }
               pMat.opacity = pBaseOpacity * fade;
           },
           update: (time: number) => {
               // Slowly spin the entire galaxy
               group.rotation.y += 0.001; 
           }
       });
    }
    
    // Positioned throughout the universe, very far apart
    createSingularity(0.25, new THREE.Vector3(-2000, 1500, -1500));
    createSingularity(0.65, new THREE.Vector3(2500, -1200, -2000));
    createSingularity(0.96, new THREE.Vector3(0, -300, 0));

    // ----------------------------------------------------
    // FLOATING MATH EQUATIONS
    // ----------------------------------------------------
    const equations = [
        "E = mc²", 
        "F = ma", 
        "∇ × E = -∂B/∂t", 
        "iℏ ∂ψ/∂t = Hψ", 
        "e^(iπ) + 1 = 0", 
        "a² + b² = c²", 
        "ΔS ≥ 0",
        "P(A|B) = P(B|A)P(A)/P(B)"
    ];
    
    equations.forEach((eq, index) => {
       const tex = createMathTexture(eq);
       const mat = new THREE.SpriteMaterial({ map: tex, transparent: true, opacity: 0.4, depthWrite: false, blending: THREE.AdditiveBlending });
       
       // Create multiple instances of each equation
       for(let i=0; i<10; i++) {
           const sprite = new THREE.Sprite(mat);
           // Randomly place along the entire path
           const prog = Math.random();
           const pt = getPathPoint(prog);
           sprite.position.set(
               pt.x + (Math.random() - 0.5) * 2000,
               pt.y + (Math.random() - 0.5) * 2000,
               pt.z + (Math.random() - 0.5) * 1000
           );
           // Scale X by 4 to match the 512x128 aspect ratio
           const scale = 15 + Math.random() * 20;
           sprite.scale.set(scale * 4, scale, 1);
           scene.add(sprite);
           
           updatables.push((time: number) => {
               sprite.position.y += Math.sin(time + index + i) * 0.2;
           });
       }
    });

    // ----------------------------------------------------
    // AMBIENT DUST
    // ----------------------------------------------------
    const dustCount = 3000;
    const dustGeo = new THREE.BufferGeometry();
    const dustPos = new Float32Array(dustCount * 3);
    for(let i=0; i<dustCount*3; i+=3) {
       dustPos[i] = (Math.random() - 0.5) * 3500;
       dustPos[i+1] = (Math.random() - 0.5) * 3500;
       dustPos[i+2] = 1500 - Math.random() * 7000; 
    }
    dustGeo.setAttribute("position", new THREE.BufferAttribute(dustPos, 3));
    const dustMat = new THREE.PointsMaterial({
       map: circleTex,
       color: 0xffffff,
       size: 3,
       transparent: true,
       opacity: 0.2, // Made dust more visible
       depthWrite: false,
       blending: THREE.AdditiveBlending
    });
    const dustSystem = new THREE.Points(dustGeo, dustMat);
    scene.add(dustSystem);

    // ----------------------------------------------------
    // INTERACTIVITY & ANIMATION
    // ----------------------------------------------------
    let mouseX = 0;
    let mouseY = 0;
    let scrollPercent = 0;
    
    const calculateScroll = () => {
        const h = document.documentElement;
        const b = document.body;
        const st = 'scrollTop';
        const sh = 'scrollHeight';
        
        const scrollAmount = (h[st] || b[st]);
        const maxScroll = (h[sh] || b[sh]) - h.clientHeight;
        
        scrollPercent = maxScroll > 0 ? scrollAmount / maxScroll : 0;
    };

    document.addEventListener("scroll", calculateScroll);
    window.addEventListener("resize", calculateScroll);

    document.addEventListener("mousemove", (event) => {
      mouseX = (event.clientX - window.innerWidth / 2) * 0.4;
      mouseY = (event.clientY - window.innerHeight / 2) * 0.4;
    });

    // EASTER EGG: Hyper-Shockwave on Double Click
    const shockwaves: any[] = [];
    document.addEventListener('dblclick', (e) => {
        const swGeo = new THREE.RingGeometry(0.1, 2, 64);
        const swMat = new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 1.0, side: THREE.DoubleSide, blending: THREE.AdditiveBlending });
        const swMesh = new THREE.Mesh(swGeo, swMat);
        
        // Project click into 3D space in front of camera
        const dir = new THREE.Vector3((e.clientX / window.innerWidth) * 2 - 1, -(e.clientY / window.innerHeight) * 2 + 1, 0.5).unproject(camera).sub(camera.position).normalize();
        const dist = 400; // spawn distance
        swMesh.position.copy(camera.position).add(dir.multiplyScalar(dist));
        swMesh.lookAt(camera.position);
        scene.add(swMesh);
        
        shockwaves.push({ mesh: swMesh, age: 0 });
    });

    let time = 0;
    
    // We need to keep track of where the camera is currently looking to smooth it
    const currentLookTarget = new THREE.Vector3(0, 0, 0);
    // Initialize look target ahead of start
    currentLookTarget.copy(getPathPoint(0.05));

    function animate() {
      requestAnimationFrame(animate);
      time += 0.015;

      // Update all scene elements (rotate/move) and apply proximity fading
      sceneElements.forEach(el => {
         el.update(time);
         el.updateFade(camera.position);
      });
      
      updatables.forEach(fn => fn(time));

      // Easter Egg Shockwave animation
      for(let i=shockwaves.length-1; i>=0; i--) {
          const sw = shockwaves[i];
          sw.age += 0.04;
          sw.mesh.scale.set(1 + sw.age * 40, 1 + sw.age * 40, 1);
          sw.mesh.material.opacity = Math.max(0, 1.0 - sw.age * 1.5);
          if(sw.age > 1.0) {
              scene.remove(sw.mesh);
              shockwaves.splice(i, 1);
          }
      }

      // Update Camera (Curvy Video Game Journey)
      
      // Calculate where we should be on the path
      const targetPos = getPathPoint(scrollPercent);
      // Add mouse parallax
      targetPos.x += mouseX;
      targetPos.y += -mouseY;
      
      // Smoothly move camera towards the target position
      camera.position.lerp(targetPos, 0.05);
      
      // Calculate where we should look (slightly ahead on the path)
      // This makes the camera bank and turn into the curves
      const lookAheadPercent = Math.min(1.0, scrollPercent + 0.08);
      const targetLookPos = getPathPoint(lookAheadPercent);
      
      // Smoothly interpolate the look target for buttery smooth turns
      currentLookTarget.lerp(targetLookPos, 0.05);
      camera.lookAt(currentLookTarget);

      renderer.render(scene, camera);
    }

    window.addEventListener("resize", () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
    
    calculateScroll();
    animate();
  }
</script>

<style>
