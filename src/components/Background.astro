---
---

<canvas id="background"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("background") as HTMLCanvasElement;

  if (canvas) {
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x000000, 0.0007);

    const camera = new THREE.PerspectiveCamera(
      75,
      window.innerWidth / window.innerHeight,
      1,
      8000
    );

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });

    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const tunnelWidth = 2200;
    const tunnelHeight = 2200;
    const tunnelLength = 7000; 

    // ----------------------------------------------------
    // 1. NEURAL NETWORK TUNNEL
    // ----------------------------------------------------
    const particleCount = 900; // Increased density
    const maxDistance = 280;
    const maxDistanceSq = maxDistance * maxDistance;

    const particles = new THREE.BufferGeometry();
    const particlePositions = new Float32Array(particleCount * 3);
    const particleVelocities = [];

    for (let i = 0; i < particleCount; i++) {
      particlePositions[i * 3] = (Math.random() - 0.5) * tunnelWidth;
      particlePositions[i * 3 + 1] = (Math.random() - 0.5) * tunnelHeight;
      particlePositions[i * 3 + 2] = 1500 - Math.random() * tunnelLength;

      particleVelocities.push({
        x: (Math.random() - 0.5) * 1.2,
        y: (Math.random() - 0.5) * 1.2,
        z: (Math.random() - 0.5) * 1.2,
      });
    }

    particles.setAttribute("position", new THREE.BufferAttribute(particlePositions, 3));

    const pMaterial = new THREE.PointsMaterial({
      color: 0xffffff,
      size: 4,
      transparent: true,
      opacity: 0.8,
      blending: THREE.AdditiveBlending,
    });

    const particleSystem = new THREE.Points(particles, pMaterial);
    scene.add(particleSystem);

    const maxLines = 20000;
    const linePositions = new Float32Array(maxLines * 6);
    const lineColors = new Float32Array(maxLines * 6);

    const linesGeometry = new THREE.BufferGeometry();
    linesGeometry.setAttribute("position", new THREE.BufferAttribute(linePositions, 3));
    linesGeometry.setAttribute("color", new THREE.BufferAttribute(lineColors, 3));
    linesGeometry.setDrawRange(0, 0);

    const lineMaterial = new THREE.LineBasicMaterial({
      vertexColors: true,
      transparent: true,
      opacity: 0.5,
      blending: THREE.AdditiveBlending,
      depthWrite: false
    });

    const linesMesh = new THREE.LineSegments(linesGeometry, lineMaterial);
    scene.add(linesMesh);

    // ----------------------------------------------------
    // 2. AMBIENT DUST (Fill emptiness)
    // ----------------------------------------------------
    const dustCount = 4000;
    const dustGeo = new THREE.BufferGeometry();
    const dustPos = new Float32Array(dustCount * 3);
    for(let i=0; i<dustCount*3; i+=3) {
       dustPos[i] = (Math.random() - 0.5) * tunnelWidth * 1.5;
       dustPos[i+1] = (Math.random() - 0.5) * tunnelHeight * 1.5;
       dustPos[i+2] = 1500 - Math.random() * tunnelLength;
    }
    dustGeo.setAttribute("position", new THREE.BufferAttribute(dustPos, 3));
    const dustMat = new THREE.PointsMaterial({
       color: 0xffffff,
       size: 1.5,
       transparent: true,
       opacity: 0.3,
       blending: THREE.AdditiveBlending
    });
    const dustSystem = new THREE.Points(dustGeo, dustMat);
    scene.add(dustSystem);

    // ----------------------------------------------------
    // 3. THICK NANOWORM (3 Interwoven Strands)
    // ----------------------------------------------------
    const wormLength = 150;
    const strands = 3;
    const wormGeometry = new THREE.BufferGeometry();
    const wormPositions = new Float32Array(wormLength * strands * 3);
    
    for(let i=0; i<wormLength * strands * 3; i++) {
        wormPositions[i] = 0;
    }
    
    wormGeometry.setAttribute('position', new THREE.BufferAttribute(wormPositions, 3));
    
    const wormMaterial = new THREE.PointsMaterial({
      color: 0xffffff,
      size: 8,
      transparent: true,
      opacity: 0.9,
      blending: THREE.AdditiveBlending
    });
    
    const worm = new THREE.Points(wormGeometry, wormMaterial);
    scene.add(worm);

    // ----------------------------------------------------
    // 4. LARGE GLOWING ORBS
    // ----------------------------------------------------
    // Simple glowing sprite simulation via large points
    const orbCount = 15;
    const orbGeo = new THREE.BufferGeometry();
    const orbPos = new Float32Array(orbCount * 3);
    for(let i=0; i<orbCount*3; i+=3) {
       orbPos[i] = (Math.random() - 0.5) * tunnelWidth;
       orbPos[i+1] = (Math.random() - 0.5) * tunnelHeight;
       orbPos[i+2] = 1500 - Math.random() * tunnelLength;
    }
    orbGeo.setAttribute("position", new THREE.BufferAttribute(orbPos, 3));
    
    const createOrbTexture = () => {
       const canvas = document.createElement('canvas');
       canvas.width = 128;
       canvas.height = 128;
       const ctx = canvas.getContext('2d');
       const gradient = ctx!.createRadialGradient(64, 64, 0, 64, 64, 64);
       gradient.addColorStop(0, 'rgba(255, 255, 255, 0.4)');
       gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
       ctx!.fillStyle = gradient;
       ctx!.fillRect(0, 0, 128, 128);
       return new THREE.CanvasTexture(canvas);
    };

    const orbMat = new THREE.PointsMaterial({
       color: 0xffffff,
       size: 600,
       map: createOrbTexture(),
       transparent: true,
       opacity: 0.15,
       blending: THREE.AdditiveBlending,
       depthWrite: false
    });
    const orbSystem = new THREE.Points(orbGeo, orbMat);
    scene.add(orbSystem);

    // ----------------------------------------------------
    // INTERACTIVITY & ANIMATION
    // ----------------------------------------------------
    let mouseX = 0;
    let mouseY = 0;
    let scrollPercent = 0;
    
    const calculateScroll = () => {
        const h = document.documentElement;
        const b = document.body;
        const st = 'scrollTop';
        const sh = 'scrollHeight';
        
        const scrollAmount = (h[st] || b[st]);
        const maxScroll = (h[sh] || b[sh]) - h.clientHeight;
        
        scrollPercent = maxScroll > 0 ? scrollAmount / maxScroll : 0;
    };

    document.addEventListener("scroll", calculateScroll);
    window.addEventListener("resize", calculateScroll);

    document.addEventListener("mousemove", (event) => {
      mouseX = (event.clientX - window.innerWidth / 2) * 0.4;
      mouseY = (event.clientY - window.innerHeight / 2) * 0.4;
    });

    let time = 0;

    function animate() {
      requestAnimationFrame(animate);
      time += 0.015;

      // Update Network Particles
      const positions = particleSystem.geometry.attributes.position.array as Float32Array;
      for (let i = 0; i < particleCount; i++) {
        positions[i * 3] += particleVelocities[i].x;
        positions[i * 3 + 1] += particleVelocities[i].y;
        positions[i * 3 + 2] += particleVelocities[i].z;

        if (Math.abs(positions[i * 3]) > tunnelWidth / 2) particleVelocities[i].x *= -1;
        if (Math.abs(positions[i * 3 + 1]) > tunnelHeight / 2) particleVelocities[i].y *= -1;
        
        if (positions[i * 3 + 2] > 1500) positions[i * 3 + 2] = -5500;
        if (positions[i * 3 + 2] < -5500) positions[i * 3 + 2] = 1500;
      }
      particleSystem.geometry.attributes.position.needsUpdate = true;

      // Update Ambient Dust
      const dPos = dustSystem.geometry.attributes.position.array as Float32Array;
      for(let i=0; i<dustCount; i++) {
         dPos[i*3] += Math.sin(time + i) * 0.5; // Slight drift
         dPos[i*3+1] += Math.cos(time + i) * 0.5;
         
         if (dPos[i * 3 + 2] > 1500) dPos[i * 3 + 2] = -5500;
      }
      dustSystem.geometry.attributes.position.needsUpdate = true;
      
      // Update Orbs
      const oPos = orbSystem.geometry.attributes.position.array as Float32Array;
      for(let i=0; i<orbCount; i++) {
         oPos[i*3+2] += 1.5; // Drift towards camera
         if (oPos[i * 3 + 2] > 1500) oPos[i * 3 + 2] = -5500;
      }
      orbSystem.geometry.attributes.position.needsUpdate = true;

      // Rebuild Neural Connections
      let vertexCount = 0;
      let colorCount = 0;

      for (let i = 0; i < particleCount; i++) {
        for (let j = i + 1; j < particleCount; j++) {
          const dx = positions[i * 3] - positions[j * 3];
          const dy = positions[i * 3 + 1] - positions[j * 3 + 1];
          const dz = positions[i * 3 + 2] - positions[j * 3 + 2];
          const distSq = dx * dx + dy * dy + dz * dz;

          if (distSq < maxDistanceSq) {
            linePositions[vertexCount++] = positions[i * 3];
            linePositions[vertexCount++] = positions[i * 3 + 1];
            linePositions[vertexCount++] = positions[i * 3 + 2];

            linePositions[vertexCount++] = positions[j * 3];
            linePositions[vertexCount++] = positions[j * 3 + 1];
            linePositions[vertexCount++] = positions[j * 3 + 2];

            const alpha = 1.0 - Math.sqrt(distSq) / maxDistance;
            const intensity = alpha * 0.9; 

            lineColors[colorCount++] = intensity;
            lineColors[colorCount++] = intensity;
            lineColors[colorCount++] = intensity;

            lineColors[colorCount++] = intensity;
            lineColors[colorCount++] = intensity;
            lineColors[colorCount++] = intensity;

            if (vertexCount >= maxLines * 6) break;
          }
        }
        if (vertexCount >= maxLines * 6) break;
      }

      linesMesh.geometry.setDrawRange(0, vertexCount / 3);
      linesMesh.geometry.attributes.position.needsUpdate = true;
      linesMesh.geometry.attributes.color.needsUpdate = true;
      
      // Update Thick Nanoworm (3 Strands)
      const wPositions = worm.geometry.attributes.position.array as Float32Array;
      const currentCameraZ = camera.position.z;
      
      for(let s=0; s<strands; s++) {
         const offset = s * wormLength * 3;
         
         // Shift strand back
         for(let i = wormLength - 1; i > 0; i--) {
            wPositions[offset + i*3] = wPositions[offset + (i-1)*3];
            wPositions[offset + i*3+1] = wPositions[offset + (i-1)*3+1];
            wPositions[offset + i*3+2] = wPositions[offset + (i-1)*3+2];
         }
         
         // Lissajous with phase offset for each strand
         const phase = s * ((Math.PI * 2) / strands);
         
         wPositions[offset] = Math.sin(time * 1.2 + phase) * 600 + Math.cos(time * 0.5) * 300;
         wPositions[offset + 1] = Math.cos(time * 1.5 + phase) * 500 + Math.sin(time * 0.7) * 300;
         wPositions[offset + 2] = currentCameraZ - 400 - Math.sin(time * 0.8) * 1000;
      }
      worm.geometry.attributes.position.needsUpdate = true;

      // Update Camera
      const startZ = 1200;
      const endZ = -4500;
      const targetZ = startZ + (endZ - startZ) * scrollPercent;
      
      camera.position.z += (targetZ - camera.position.z) * 0.08;
      camera.position.x += (mouseX - camera.position.x) * 0.05;
      camera.position.y += (-mouseY - camera.position.y) * 0.05;
      
      camera.lookAt(scene.position.x, scene.position.y, targetZ - 1000); 

      renderer.render(scene, camera);
    }

    window.addEventListener("resize", () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
    
    calculateScroll();
    animate();
  }
</script>

<style>
  #background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: transparent;
    pointer-events: none;
  }
</style>
