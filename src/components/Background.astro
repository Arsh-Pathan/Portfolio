<canvas id="background"></canvas>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("background") as HTMLCanvasElement;

  if (canvas) {
    const scene = new THREE.Scene();
    // Removed Fog to keep pure black/white visibility throughout the journey

    const camera = new THREE.PerspectiveCamera(
      75,
      window.innerWidth / window.innerHeight,
      1,
      8000
    );

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
    });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // ----------------------------------------------------
    // TEXTURE GENERATORS (No more square boxes)
    // ----------------------------------------------------
    const createCircleTexture = (glow = false) => {
       const texCanvas = document.createElement('canvas');
       texCanvas.width = 64;
       texCanvas.height = 64;
       const ctx = texCanvas.getContext('2d');
       if(glow) {
           const gradient = ctx!.createRadialGradient(32, 32, 0, 32, 32, 32);
           gradient.addColorStop(0, 'rgba(255, 255, 255, 1)');
           gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
           ctx!.fillStyle = gradient;
           ctx!.fillRect(0, 0, 64, 64);
       } else {
           ctx!.beginPath();
           ctx!.arc(32, 32, 30, 0, 2 * Math.PI);
           ctx!.fillStyle = 'white';
           ctx!.fill();
       }
       return new THREE.CanvasTexture(texCanvas);
    };
    
    const circleTex = createCircleTexture(false);
    const glowTex = createCircleTexture(true);

    // ----------------------------------------------------
    // ZONE 1: FLOATING NEURAL NETWORKS
    // ----------------------------------------------------
    const clusters: THREE.Group[] = [];
    function createCluster(x: number, y: number, z: number) {
       const count = 120;
       const geo = new THREE.BufferGeometry();
       const pos = new Float32Array(count * 3);
       for(let i=0; i<count*3; i+=3) {
          pos[i] = (Math.random()-0.5)*500;
          pos[i+1] = (Math.random()-0.5)*500;
          pos[i+2] = (Math.random()-0.5)*500;
       }
       geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
       
       const mat = new THREE.PointsMaterial({ 
           map: circleTex, 
           size: 5, 
           color: 0xffffff, 
           transparent: true, 
           opacity: 0.15, 
           depthWrite: false 
       });
       const pts = new THREE.Points(geo, mat);
       
       // Pre-calculate lines for cluster
       const lPos = [];
       for(let i=0; i<count; i++) {
           for(let j=i+1; j<count; j++) {
               const dx = pos[i*3] - pos[j*3];
               const dy = pos[i*3+1] - pos[j*3+1];
               const dz = pos[i*3+2] - pos[j*3+2];
               if(dx*dx + dy*dy + dz*dz < 150*150) {
                   lPos.push(pos[i*3], pos[i*3+1], pos[i*3+2], pos[j*3], pos[j*3+1], pos[j*3+2]);
               }
           }
       }
       const lGeo = new THREE.BufferGeometry();
       lGeo.setAttribute('position', new THREE.Float32BufferAttribute(lPos, 3));
       const lMat = new THREE.LineBasicMaterial({ 
           color: 0xffffff, 
           transparent: true, 
           opacity: 0.05, 
           depthWrite: false 
       });
       const lines = new THREE.LineSegments(lGeo, lMat);
       
       const group = new THREE.Group();
       group.add(pts);
       group.add(lines);
       group.position.set(x, y, z);
       scene.add(group);
       clusters.push(group);
    }
    
    // Positioned in the early scroll zone
    createCluster(200, 100, 800);
    createCluster(-300, -100, 400);
    createCluster(100, 250, 0);

    // ----------------------------------------------------
    // ZONE 2: NANOPARTICLE WORMS (Microscopic Creatures)
    // ----------------------------------------------------
    const worms: any[] = [];
    function createWorm(baseZ: number) {
        const spineLength = 60;
        const particlesPerSegment = 10;
        const totalParticles = spineLength * particlesPerSegment;
        
        const geo = new THREE.BufferGeometry();
        const pos = new Float32Array(totalParticles * 3);
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        
        const mat = new THREE.PointsMaterial({ 
            map: glowTex, 
            size: 10, 
            color: 0xffffff, 
            transparent: true, 
            opacity: 0.25, 
            depthWrite: false, 
            blending: THREE.AdditiveBlending 
        });
        const pts = new THREE.Points(geo, mat);
        scene.add(pts);
        
        worms.push({
           pts,
           baseZ,
           timeOffset: Math.random() * 100,
           update: function(t: number) {
               const positions = this.pts.geometry.attributes.position.array;
               const tt = t + this.timeOffset;
               
               for(let s=0; s<spineLength; s++) {
                   const st = tt - s * 0.03; // Time delay for trailing segments
                   
                   // Core spine movement (Lissajous curves)
                   const cx = Math.sin(st * 1.2) * 400;
                   const cy = Math.cos(st * 0.9) * 300;
                   const cz = this.baseZ + Math.sin(st * 0.5) * 600;
                   
                   // Particles orbiting the spine at this segment
                   for(let p=0; p<particlesPerSegment; p++) {
                       const idx = (s * particlesPerSegment + p) * 3;
                       const angle = (p / particlesPerSegment) * Math.PI * 2 + st * 3;
                       // Radius breathes/pulsates
                       const radius = 25 + Math.sin(st * 5 + p) * 15; 
                       
                       positions[idx] = cx + Math.cos(angle) * radius;
                       positions[idx+1] = cy + Math.sin(angle) * radius;
                       positions[idx+2] = cz + Math.cos(angle * 0.5) * radius;
                   }
               }
               this.pts.geometry.attributes.position.needsUpdate = true;
           }
        });
    }
    
    // Positioned in the middle scroll zone
    createWorm(-800);
    createWorm(-1600);

    // ----------------------------------------------------
    // ZONE 3: MACRO STRUCTURES (Bigger Things)
    // ----------------------------------------------------
    const macros: THREE.Group[] = [];
    function createMacro(x: number, y: number, z: number, radius: number) {
       const geo = new THREE.IcosahedronGeometry(radius, 2);
       
       // Edges for wireframe look
       const edges = new THREE.EdgesGeometry(geo);
       const lMat = new THREE.LineBasicMaterial({ 
           color: 0xffffff, 
           transparent: true, 
           opacity: 0.04, 
           depthWrite: false 
       });
       const mesh = new THREE.LineSegments(edges, lMat);
       
       // Points at vertices
       const pMat = new THREE.PointsMaterial({ 
           map: glowTex, 
           size: 15, 
           color: 0xffffff, 
           transparent: true, 
           opacity: 0.1, 
           depthWrite: false 
       });
       const pts = new THREE.Points(geo, pMat);
       
       const group = new THREE.Group();
       group.add(mesh);
       group.add(pts);
       group.position.set(x, y, z);
       scene.add(group);
       macros.push(group);
    }
    
    // Positioned in the deep scroll zone
    createMacro(-300, 200, -2800, 400);
    createMacro(400, -100, -3800, 500);
    createMacro(0, 0, -4800, 600);

    // ----------------------------------------------------
    // AMBIENT DUST
    // ----------------------------------------------------
    const dustCount = 3000;
    const dustGeo = new THREE.BufferGeometry();
    const dustPos = new Float32Array(dustCount * 3);
    for(let i=0; i<dustCount*3; i+=3) {
       dustPos[i] = (Math.random() - 0.5) * 2500;
       dustPos[i+1] = (Math.random() - 0.5) * 2500;
       dustPos[i+2] = 1200 - Math.random() * 6500; // Span entire journey
    }
    dustGeo.setAttribute("position", new THREE.BufferAttribute(dustPos, 3));
    const dustMat = new THREE.PointsMaterial({
       map: circleTex,
       color: 0xffffff,
       size: 2,
       transparent: true,
       opacity: 0.08, // Very subtle
       depthWrite: false,
       blending: THREE.AdditiveBlending
    });
    const dustSystem = new THREE.Points(dustGeo, dustMat);
    scene.add(dustSystem);

    // ----------------------------------------------------
    // INTERACTIVITY & ANIMATION
    // ----------------------------------------------------
    let mouseX = 0;
    let mouseY = 0;
    let scrollPercent = 0;
    
    const calculateScroll = () => {
        const h = document.documentElement;
        const b = document.body;
        const st = 'scrollTop';
        const sh = 'scrollHeight';
        
        const scrollAmount = (h[st] || b[st]);
        const maxScroll = (h[sh] || b[sh]) - h.clientHeight;
        
        scrollPercent = maxScroll > 0 ? scrollAmount / maxScroll : 0;
    };

    document.addEventListener("scroll", calculateScroll);
    window.addEventListener("resize", calculateScroll);

    document.addEventListener("mousemove", (event) => {
      mouseX = (event.clientX - window.innerWidth / 2) * 0.4;
      mouseY = (event.clientY - window.innerHeight / 2) * 0.4;
    });

    let time = 0;

    function animate() {
      requestAnimationFrame(animate);
      time += 0.015;

      // Rotate Neural Clusters
      clusters.forEach((cluster, i) => {
          cluster.rotation.x = time * 0.1 * (i % 2 === 0 ? 1 : -1);
          cluster.rotation.y = time * 0.15;
      });
      
      // Update Nanoparticle Worms
      worms.forEach(w => w.update(time));
      
      // Rotate Macro Structures
      macros.forEach((macro, i) => {
          macro.rotation.x = time * 0.05;
          macro.rotation.y = time * 0.08 * (i % 2 === 0 ? 1 : -1);
      });

      // Update Camera (Microscopic Journey)
      const startZ = 1200;
      const endZ = -4500;
      const targetZ = startZ + (endZ - startZ) * scrollPercent;
      
      camera.position.z += (targetZ - camera.position.z) * 0.08;
      camera.position.x += (mouseX - camera.position.x) * 0.05;
      camera.position.y += (-mouseY - camera.position.y) * 0.05;
      
      camera.lookAt(scene.position.x, scene.position.y, targetZ - 1000); 

      renderer.render(scene, camera);
    }

    window.addEventListener("resize", () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
    
    calculateScroll();
    animate();
  }
</script>

<style>
  #background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: transparent;
    pointer-events: none;
  }
</style>
