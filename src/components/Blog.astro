---
const posts = [
  {
    title: "The Future of Agentic AI Workflows",
    date: "Oct 12, 2024",
    readTime: "5 min read",
    tag: "Machine Learning",
    href: "#"
  },
  {
    title: "Scaling Go Backends for LLM Inferences",
    date: "Sep 28, 2024",
    readTime: "8 min read",
    tag: "Engineering",
    href: "#"
  },
  {
    title: "Lessons from Building CSky Developments",
    date: "Aug 15, 2024",
    readTime: "6 min read",
    tag: "Founder",
    href: "#"
  }
];
---

<section id="insights" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="h-[1px] w-8 bg-white/50"></div>
          <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Writing</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
          Recent <span class="text-white/40">Insights</span>
        </h2>
      </div>
      <a href="#" class="group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors">
        Read all articles
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>

    <div class="flex flex-col gap-6">
      {posts.map((post) => (
        <a href={post.href} class="blog-row group block relative p-8 md:p-10 bg-white/[0.01] hover:bg-white/[0.03] border border-white/5 hover:border-white/20 rounded-3xl backdrop-blur-sm transition-all duration-300">
           <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
             <div class="flex-grow">
               <div class="flex items-center gap-4 mb-3">
                 <span class="text-xs font-bold uppercase tracking-widest text-white/40">{post.tag}</span>
                 <span class="w-1 h-1 rounded-full bg-white/20"></span>
                 <span class="text-xs font-medium text-white/40">{post.readTime}</span>
               </div>
               <h3 class="text-2xl md:text-3xl font-bold text-white group-hover:text-white/80 transition-colors">{post.title}</h3>
             </div>
             
             <div class="flex items-center justify-between md:justify-end gap-8 md:w-48 flex-shrink-0">
                <span class="text-sm font-medium text-white/50">{post.date}</span>
                <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-white group-hover:text-black text-white transition-all duration-300 transform group-hover:rotate-45">
                   <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
             </div>
           </div>
        </a>
      ))}
    </div>
    
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.from(".blog-row", {
      scrollTrigger: {
        trigger: "#insights",
        start: "top 80%",
      },
      x: -30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: "power2.out"
    });
  });
</script>
