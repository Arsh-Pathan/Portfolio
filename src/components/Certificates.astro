---
/**
 * Refined, professional Certificates section.
 * Clean grid layout emphasizing credentials.
 */

const certificates = [
  {
    title: "3rd Place - VibeState '25",
    issuer: "Singularity",
    description: "Awarded 3rd Place in the VibeState'25 competition for outstanding performance and hard work.",
    date: "Feb 2025",
    icon: "",
    url: "#"
  },
  {
    title: "Gen AI Engineering Mastermind",
    issuer: "Outskill",
    description: "Successfully completed an intensive program on Generative AI Engineering and Agentic AI systems.",
    date: "2025",
    icon: "",
    url: "#"
  },
  {
    title: "Certificate of Participation",
    issuer: "Unstop",
    description: "Participated in VibeState '25 organized by Guru Gobind Singh Indraprastha University (GGSIPU), Delhi.",
    date: "Feb 2025",
    icon: "",
    url: "#"
  }
];
---

<section id="certificates" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-8 bg-white/50"></div>
        <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Recognition</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
        Certificates & <span class="text-white/40">Achievements</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {certificates.map((cert) => (
        <a href={cert.url} target="_blank" class="group block relative p-8 bg-[#111111]/40 hover:bg-[#1f1f1f]/80 rounded-[24px] border border-white/5 hover:border-white/20 transition-all duration-500 overflow-hidden flex flex-col h-full">
          <div class="mb-8 w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-500">
            {cert.icon}
          </div>
          
          <div class="flex-grow">
            <h3 class="text-xl font-medium text-white mb-2">{cert.title}</h3>
            <p class="text-xs font-bold text-white/80 uppercase tracking-widest mb-4">{cert.issuer}</p>
            <p class="text-[#8b949e] text-sm leading-relaxed mb-6">
              {cert.description}
            </p>
          </div>

          <div class="flex items-center justify-between border-t border-white/5 pt-6 mt-auto">
            <span class="text-xs font-medium text-white/40">{cert.date}</span>
            <div class="flex items-center gap-1.5 text-xs font-medium text-white/80 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all duration-300">
              View Credential
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
