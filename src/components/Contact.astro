---
/**
 * Professional, clean Contact section.
 */
---

<section id="contact" class="py-32 relative z-10 bg-transparent">
  <div class="container max-w-7xl mx-auto px-6">
    
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-8 bg-white/50"></div>
        <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Connect</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
        Let's start a <span class="text-white/40">conversation</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left Info -->
      <div class="flex flex-col">
        <p class="text-[#8b949e] text-lg leading-relaxed mb-12 max-w-md">
          I'm always open to discussing new projects, technical architectures, or opportunities to be part of your vision.
        </p>

        <div class="space-y-8">
          <div class="flex items-center gap-6">
            <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-white/50 mb-1 uppercase tracking-wider">Email</p>
              <a href="mailto:mail.arsh.pathan@gmail.com" class="text-white font-medium hover:text-white transition-colors">mail.arsh.pathan@gmail.com</a>
            </div>
          </div>

          <div class="flex items-center gap-6">
            <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <p class="text-xs font-medium text-white/50 mb-1 uppercase tracking-wider">Phone</p>
              <a href="tel:+919923836512" class="text-white font-medium hover:text-white transition-colors">+91 9923836512</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Form -->
      <div class="bg-[#0d1427]/40 p-8 rounded-[32px] border border-white/5 relative overflow-hidden backdrop-blur-md">
        <form class="flex flex-col gap-6 relative z-10">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-xs font-medium text-white/60 pl-1">Name</label>
              <input type="text" id="name" placeholder="John Doe" class="w-full bg-[#111a30] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/30 outline-none focus:border-white/50 transition-colors" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="text-xs font-medium text-white/60 pl-1">Email</label>
              <input type="email" id="email" placeholder="john@example.com" class="w-full bg-[#111a30] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/30 outline-none focus:border-white/50 transition-colors" />
            </div>
          </div>
          
          <div class="flex flex-col gap-2">
            <label for="message" class="text-xs font-medium text-white/60 pl-1">Message</label>
            <textarea id="message" rows="4" placeholder="How can I help you?" class="w-full bg-[#111a30] border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-white/30 outline-none focus:border-white/50 transition-colors resize-none"></textarea>
          </div>

          <button type="button" class="mt-2 w-full py-4 bg-white text-black font-semibold rounded-xl hover:bg-white/90 transition-colors flex items-center justify-center gap-2">
            Send Message
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </button>
        </form>
      </div>
      
    </div>
  </div>
</section>
