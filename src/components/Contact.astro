---
/**
 * Professional, clean Contact section.
 */
---

<section id="contact" class="py-32 relative z-10 bg-transparent">
  <div class="container max-w-7xl mx-auto px-6 relative">
    
    <!-- Decorative background element -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.01] rounded-full blur-[100px] pointer-events-none z-[-1]"></div>

    <div class="mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-12 bg-white/50"></div>
        <span class="text-[10px] font-mono font-bold tracking-[0.2em] text-white/80 uppercase">Transmission_Node</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
        Initialize <span class="text-white/40 italic">Connection</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left Info -->
      <div class="flex flex-col relative">
        <div class="absolute -left-8 top-0 w-[1px] h-full bg-gradient-to-b from-white/20 via-white/5 to-transparent hidden md:block"></div>
        
        <p class="text-white/50 text-sm leading-relaxed mb-12 max-w-md font-mono">
          > SYSTEM STANDBY... <br/>
          > AWAITING HANDSHAKE PROTOCOL. <br/>
          <br/>
          > I'm always open to discussing technical architectures, complex integrations, or opportunities to build the future.
        </p>

        <div class="space-y-6">
          <div class="group flex items-center gap-6 p-4 rounded-xl hover:bg-white/[0.03] transition-colors border border-transparent hover:border-white/10 cursor-pointer">
            <div class="w-12 h-12 rounded-xl bg-black border border-white/20 flex items-center justify-center text-white/80 group-hover:scale-110 group-hover:bg-white group-hover:text-black transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <p class="text-[10px] font-mono font-bold text-white/40 mb-1 uppercase tracking-widest">Protocol // Email</p>
              <a href="mailto:mail.arsh.pathan@gmail.com" class="text-white font-medium hover:text-white transition-colors text-sm">mail.arsh.pathan@gmail.com</a>
            </div>
          </div>

          <div class="group flex items-center gap-6 p-4 rounded-xl hover:bg-white/[0.03] transition-colors border border-transparent hover:border-white/10 cursor-pointer">
            <div class="w-12 h-12 rounded-xl bg-black border border-white/20 flex items-center justify-center text-white/80 group-hover:scale-110 group-hover:bg-white group-hover:text-black transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <p class="text-[10px] font-mono font-bold text-white/40 mb-1 uppercase tracking-widest">Protocol // Voice</p>
              <a href="tel:+919923836512" class="text-white font-medium hover:text-white transition-colors text-sm">+91 9923836512</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Form (Terminal Style) -->
      <div class="relative group/form">
        <!-- Corner accents -->
        <div class="absolute -top-1 -left-1 w-4 h-4 border-t-2 border-l-2 border-white/50 z-20"></div>
        <div class="absolute -top-1 -right-1 w-4 h-4 border-t-2 border-r-2 border-white/50 z-20"></div>
        <div class="absolute -bottom-1 -left-1 w-4 h-4 border-b-2 border-l-2 border-white/50 z-20"></div>
        <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b-2 border-r-2 border-white/50 z-20"></div>
        
        <div class="bg-black/80 p-8 md:p-10 border border-white/10 relative overflow-hidden backdrop-blur-xl">
          <!-- Scanline effect -->
          <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:100%_4px] pointer-events-none opacity-50"></div>
          
          <div class="flex justify-between items-center mb-8 pb-4 border-b border-white/10 relative z-10">
            <span class="text-[10px] font-mono tracking-widest text-white/50">SECURE_CHANNEL_OPEN</span>
            <div class="flex gap-1.5 items-center">
              <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
              <span class="text-[10px] font-mono text-white tracking-widest">LIVE</span>
            </div>
          </div>

          <form class="flex flex-col gap-8 relative z-10">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
              <div class="flex flex-col gap-3 relative">
                <label for="name" class="text-[10px] font-mono font-bold tracking-widest text-white/40 uppercase">IDENTIFIER [NAME]</label>
                <input type="text" id="name" placeholder="> Enter ID" class="w-full bg-transparent border-b border-white/20 px-0 py-2 text-sm text-white placeholder-white/20 outline-none focus:border-white transition-colors font-mono" />
              </div>
              <div class="flex flex-col gap-3 relative">
                <label for="email" class="text-[10px] font-mono font-bold tracking-widest text-white/40 uppercase">RETURN_PATH [EMAIL]</label>
                <input type="email" id="email" placeholder="> Enter Email" class="w-full bg-transparent border-b border-white/20 px-0 py-2 text-sm text-white placeholder-white/20 outline-none focus:border-white transition-colors font-mono" />
              </div>
            </div>
            
            <div class="flex flex-col gap-3 relative">
              <label for="message" class="text-[10px] font-mono font-bold tracking-widest text-white/40 uppercase">PAYLOAD [MESSAGE]</label>
              <textarea id="message" rows="3" placeholder="> Enter Data..." class="w-full bg-transparent border-b border-white/20 px-0 py-2 text-sm text-white placeholder-white/20 outline-none focus:border-white transition-colors resize-none font-mono"></textarea>
            </div>

            <button type="button" class="mt-4 w-full py-4 bg-white text-black font-mono font-bold tracking-widest text-xs uppercase hover:bg-white/80 transition-all flex items-center justify-center gap-3 group/btn">
              <span>Transmit Payload</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
          </form>
        </div>
      </div>
      
    </div>
  </div>
</section>
