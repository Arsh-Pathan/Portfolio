---
const experience = [
  {
    role: "Technical Lead",
    company: "AIML Club, DPCOE",
    period: "2024 - Present",
    description: "Piloting technical innovation for the college's AI club. Organizing hackathon initiatives like NeuroBoard and presenting research papers on AI's impact.",
  },
  {
    role: "Founder & Lead Developer",
    company: "CSky Developments",
    period: "2020 - Present",
    description: "Founded and actively manage a Minecraft server development community of 400+ members. Developed 20+ custom Java plugins supporting 100+ server owners and 500+ daily players. Monetized solutions via BuiltByBit, reaching 50+ premium clients.",
  },
  {
    role: "Open Source Contributor",
    company: "GitHub Community",
    period: "2020 - Present",
    description: "Fixed critical framework documentation flows via PR integrations into Meta/HuggingFace's OpenEnv repository. Maintained open-source discipline across 36 repositories with 650+ contributions.",
  },
];
---

<section id="experience" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-4xl">
    
    <div class="mb-20 text-center flex flex-col items-center">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-8 bg-white/50"></div>
        <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Journey</span>
        <div class="h-[1px] w-8 bg-white/50"></div>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
        Experience & <span class="text-white/40">Evolution</span>
      </h2>
    </div>

    <div class="relative wrap overflow-hidden p-10 h-full">
      <!-- Vertical line -->
      <div class="border-2-2 absolute border-opacity-20 border-white h-full border left-1/2 -ml-[1px]"></div>
      
      {experience.map((item, index) => (
        <div class={`mb-12 flex justify-between items-center w-full timeline-item ${index % 2 === 0 ? 'flex-row-reverse left-timeline' : 'right-timeline'}`}>
          <div class="order-1 w-5/12"></div>
          
          <div class="z-20 flex items-center order-1 bg-[#111111] shadow-xl w-4 h-4 rounded-full border-4 border-white/20 timeline-dot">
          </div>
          
          <div class="order-1 bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 w-5/12 backdrop-blur-md hover:bg-white/10 transition-colors duration-500 timeline-card">
            <h3 class="font-bold text-white text-xl md:text-2xl mb-1">{item.role}</h3>
            <h4 class="font-medium text-white/60 text-sm md:text-base mb-4">{item.company} <span class="mx-2">•</span> {item.period}</h4>
            <p class="text-sm leading-relaxed text-white/50">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>
    
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const items = document.querySelectorAll('.timeline-item');
    
    items.forEach((item, i) => {
      const card = item.querySelector('.timeline-card');
      const dot = item.querySelector('.timeline-dot');
      
      const isLeft = i % 2 === 0;
      
      gsap.from(card, {
        scrollTrigger: {
          trigger: item,
          start: "top 80%",
        },
        x: isLeft ? 50 : -50,
        opacity: 0,
        duration: 1,
        ease: "power3.out"
      });
      
      gsap.from(dot, {
        scrollTrigger: {
          trigger: item,
          start: "top 80%",
        },
        scale: 0,
        opacity: 0,
        duration: 0.5,
        delay: 0.2,
        ease: "back.out(2)"
      });
    });
  });
</script>

<style>
  @media (max-width: 768px) {
    .timeline-item {
      flex-direction: column !important;
      align-items: flex-start;
      padding-left: 2rem;
      position: relative;
    }
    .wrap > .border-2-2 {
      left: 1rem;
    }
    .timeline-item > div.w-5\/12 {
      width: 100%;
    }
    .timeline-dot {
      position: absolute;
      left: 1rem;
      transform: translateX(-50%);
    }
    .timeline-card {
      margin-top: 1rem;
    }
  }
</style>
