---
// Gallery images — add your own files to public/gallery/
const photos = [
  { src: "/gallery/photo1.png", alt: "Moment 1", span: "tall", caption: "Behind the code" },
  { src: "/gallery/photo2.png", alt: "Moment 2", span: "wide", caption: "Creative process" },
  { src: "/gallery/photo3.png", alt: "Moment 3", span: "normal", caption: "Late nights" },
  { src: "/gallery/photo4.png", alt: "Moment 4", span: "normal", caption: "Inspiration" },
  { src: "/gallery/photo5.png", alt: "Moment 5", span: "wide", caption: "The journey" },
  { src: "/gallery/photo6.png", alt: "Moment 6", span: "tall", caption: "Milestone" },
  { src: "/gallery/photo7.png", alt: "Moment 7", span: "wide", caption: "Building" },
  { src: "/gallery/photo8.png", alt: "Moment 8", span: "normal", caption: "Discovery" },
  { src: "/gallery/photo9.png", alt: "Moment 9", span: "normal", caption: "Progress" },
  { src: "/gallery/photo10.png", alt: "Moment 10", span: "wide", caption: "Growth" },
];
---

<section id="gallery" class="gallery-section relative py-32 overflow-hidden">
  <!-- Section header -->
  <div class="container text-center mb-20">
    <div class="section-label justify-center flex">Moments</div>
    <h2 class="section-title">
      Behind the <span class="gradient-text">Code</span>
    </h2>
    <p class="text-text-muted max-w-xl mx-auto -mt-4">
      A glimpse into the world beyond the terminal.
    </p>
  </div>

  <!-- Bento Grid -->
  <div class="gallery-grid mx-auto px-6" style="max-width: 1300px;">
    {photos.map((photo, i) => (
      <div
        class={`gallery-item gallery-${photo.span}`}
        data-index={i}
        data-src={photo.src}
        data-caption={photo.caption}
        style={`--delay: ${i * 0.07}s`}
      >
        <div class="gallery-inner">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <!-- Overlay -->
          <div class="gallery-overlay" />
          <!-- Caption -->
          <div class="gallery-caption">
            <span class="gallery-caption-text">{photo.caption}</span>
          </div>
          <!-- Number tag -->
          <span class="gallery-tag">0{i + 1}</span>
          <!-- Hover expand icon -->
          <div class="gallery-expand">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
            </svg>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div id="gallery-lightbox" class="gallery-lightbox">
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
  <div class="lightbox-content" id="lightbox-content">
    <img id="lightbox-image" src="" alt="Gallery" />
    <div class="lightbox-caption" id="lightbox-caption"></div>
    <button class="lightbox-close" id="lightbox-close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <button class="lightbox-nav lightbox-prev" id="lightbox-prev">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button class="lightbox-nav lightbox-next" id="lightbox-next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const items = document.querySelectorAll(".gallery-item");

    // Scroll reveal animations
    items.forEach((item, i) => {
      const fromX = i % 3 === 0 ? -60 : i % 3 === 1 ? 0 : 60;
      const fromY = i % 3 === 1 ? 60 : 0;

      gsap.fromTo(
        item,
        {
          opacity: 0,
          x: fromX,
          y: fromY,
          scale: 0.88,
          rotateZ: i % 2 === 0 ? -1.5 : 1.5,
          filter: "blur(8px)",
        },
        {
          opacity: 1,
          x: 0,
          y: 0,
          scale: 1,
          rotateZ: 0,
          filter: "blur(0px)",
          duration: 1.1,
          ease: "expo.out",
          scrollTrigger: {
            trigger: item,
            start: "top 88%",
            toggleActions: "play none none reverse",
          },
        }
      );
    });

    // Lightbox logic
    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImage = document.getElementById("lightbox-image") as HTMLImageElement;
    const lightboxCaption = document.getElementById("lightbox-caption");
    const lightboxCounter = document.getElementById("lightbox-counter");
    const lightboxClose = document.getElementById("lightbox-close");
    const lightboxBackdrop = document.getElementById("lightbox-backdrop");
    const lightboxPrev = document.getElementById("lightbox-prev");
    const lightboxNext = document.getElementById("lightbox-next");
    const lightboxContent = document.getElementById("lightbox-content");

    const allItems = Array.from(items);
    let currentIndex = 0;

    function openLightbox(index: number) {
      currentIndex = index;
      const item = allItems[currentIndex];
      const src = item.getAttribute("data-src") || "";
      const caption = item.getAttribute("data-caption") || "";

      if (lightboxImage) lightboxImage.src = src;
      if (lightboxCaption) lightboxCaption.textContent = caption;
      if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${allItems.length}`;

      lightbox?.classList.add("open");
      document.body.style.overflow = "hidden";

      gsap.fromTo(lightboxContent, 
        { scale: 0.85, opacity: 0, y: 40 },
        { scale: 1, opacity: 1, y: 0, duration: 0.5, ease: "power3.out" }
      );
    }

    function closeLightbox() {
      gsap.to(lightboxContent, {
        scale: 0.9, opacity: 0, y: 20, duration: 0.3,
        onComplete: () => {
          lightbox?.classList.remove("open");
          document.body.style.overflow = "";
        }
      });
    }

    function navigateLightbox(direction: number) {
      currentIndex = (currentIndex + direction + allItems.length) % allItems.length;
      const item = allItems[currentIndex];
      const src = item.getAttribute("data-src") || "";
      const caption = item.getAttribute("data-caption") || "";

      gsap.to(lightboxImage, {
        opacity: 0, x: direction * -30, duration: 0.2,
        onComplete: () => {
          if (lightboxImage) lightboxImage.src = src;
          if (lightboxCaption) lightboxCaption.textContent = caption;
          if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${allItems.length}`;
          gsap.fromTo(lightboxImage, 
            { opacity: 0, x: direction * 30 },
            { opacity: 1, x: 0, duration: 0.3, ease: "power2.out" }
          );
        }
      });
    }

    items.forEach((item, i) => {
      item.addEventListener("click", () => openLightbox(i));
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightboxBackdrop?.addEventListener("click", closeLightbox);
    lightboxPrev?.addEventListener("click", () => navigateLightbox(-1));
    lightboxNext?.addEventListener("click", () => navigateLightbox(1));
    document.addEventListener("keydown", (e) => {
      if (!lightbox?.classList.contains("open")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") navigateLightbox(-1);
      if (e.key === "ArrowRight") navigateLightbox(1);
    });
  });
</script>

<style>
  .gallery-section {
    background: linear-gradient(to bottom, #0a0f1c, #060a14);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 16px;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }
    .gallery-wide { grid-column: span 2; }
    .gallery-tall { grid-row: span 1; }
  }

  .gallery-item {
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    position: relative;
    will-change: transform, opacity, filter;
  }

  .gallery-tall { grid-row: span 2; }
  .gallery-wide { grid-column: span 2; }
  .gallery-normal { grid-column: span 1; grid-row: span 1; }

  .gallery-inner {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .gallery-inner img {
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-item:hover .gallery-inner img {
    transform: scale(1.08);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(6,10,20,0.7) 0%, transparent 50%);
    opacity: 0.6;
    transition: opacity 0.4s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 0.9;
  }

  .gallery-caption {
    position: absolute;
    bottom: 40px;
    left: 14px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s ease;
  }

  .gallery-caption-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    text-transform: capitalize;
  }

  .gallery-item:hover .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-tag {
    position: absolute;
    bottom: 14px;
    right: 14px;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.4);
    font-family: monospace;
    transition: color 0.3s ease;
  }

  .gallery-item:hover .gallery-tag {
    color: rgba(96, 165, 250, 0.8);
  }

  .gallery-expand {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.2);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(59, 130, 246, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
  }

  .gallery-item:hover .gallery-expand {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }

  /* Lightbox */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s ease;
  }

  .gallery-lightbox.open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(30px);
  }

  .lightbox-content {
    position: relative;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: absolute;
    top: -50px;
    right: 0;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: rotate(90deg);
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .lightbox-nav:hover {
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.4);
  }

  .lightbox-prev { left: -70px; }
  .lightbox-next { right: -70px; }

  .lightbox-caption {
    position: absolute;
    bottom: -40px;
    left: 0;
    color: #94a3c4;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .lightbox-counter {
    position: absolute;
    bottom: -40px;
    right: 0;
    color: #5a6d8a;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
  }

  @media (max-width: 768px) {
    .lightbox-prev { left: 10px; }
    .lightbox-next { right: 10px; }
    .lightbox-nav { width: 40px; height: 40px; }
    .lightbox-close { top: -40px; right: 10px; }
  }
</style>
