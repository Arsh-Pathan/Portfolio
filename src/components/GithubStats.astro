---
/**
 * Interactive GSAP horizontal scrolling Math section.
 */
---

<section id="math-journey" class="relative z-10 bg-transparent min-h-screen w-full overflow-hidden flex items-center">
  
  <div class="math-scroll-wrapper flex items-center gap-32 px-10 md:px-[10vw] h-full w-max flex-nowrap py-20 md:py-0">
    
    <!-- Title Area (First Slide) -->
    <div class="w-full md:w-[80vw] md:max-w-4xl flex-shrink-0 flex flex-col justify-center">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-[1px] w-12 bg-white/50"></div>
        <span class="text-xs font-bold tracking-widest text-white/80 uppercase">Core Principles</span>
      </div>
      <h2 class="text-6xl md:text-9xl font-black uppercase tracking-tighter leading-none mb-8" id="math-title">
        <div class="overflow-hidden"><span class="block title-line translate-y-full text-white/10">INTELLIGENT</span></div>
        <div class="overflow-hidden"><span class="block title-line translate-y-full text-white/40">SYSTEMS</span></div>
      </h2>
      <p class="text-white/60 text-lg md:text-xl max-w-lg leading-relaxed font-medium">
        At the heart of autonomous agents lies the mathematics of reinforcement learning. Scroll horizontally to explore the Bellman Equation that drives Q-Learning.
      </p>
    </div>

    <!-- The Massive Formula -->
    <div class="flex-shrink-0 flex items-center">
       <div class="math-formula flex items-center text-[5rem] md:text-[12rem] font-serif italic text-white whitespace-nowrap tracking-tight">
          <span class="drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">Q(s, a)</span>
          <span class="text-white/50 text-[3rem] md:text-[8rem] mx-8 md:mx-16 font-sans">&#8592;</span>
          <span class="drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">Q(s, a)</span>
          <span class="text-white/50 mx-8 md:mx-16 font-sans">+</span>
          <span class="text-[#cccccc] drop-shadow-[0_0_40px_rgba(255,255,255,0.4)]">&alpha;</span>
          <span class="text-white/30 mx-4 font-sans">[</span>
          <span class="drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">R(s, a)</span>
          <span class="text-white/50 mx-8 md:mx-16 font-sans">+</span>
          <span class="text-[#cccccc] drop-shadow-[0_0_40px_rgba(255,255,255,0.4)]">&gamma;</span>
          
          <div class="flex flex-col items-center justify-center translate-y-4 md:translate-y-12 mx-8 md:mx-12 font-sans">
            <span class="leading-none text-[3rem] md:text-[7rem] font-bold">max</span>
            <span class="text-white/60 leading-none text-[1.5rem] md:text-[3rem] italic">a'</span>
          </div>
          
          <span class="drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">Q(s', a')</span>
          <span class="text-white/50 mx-8 md:mx-16 font-sans">-</span>
          <span class="drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">Q(s, a)</span>
          <span class="text-white/30 mx-4 font-sans">]</span>
       </div>
    </div>
    
    <!-- End Spacer to allow smooth transition -->
    <div class="w-[20vw] flex-shrink-0"></div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
     const wrapper = document.querySelector('.math-scroll-wrapper') as HTMLElement;
     if (!wrapper) return;
     
     // Animate Title
     gsap.to('.title-line', {
       y: 0,
       duration: 1,
       stagger: 0.2,
       ease: "power4.out",
       scrollTrigger: {
         trigger: "#math-journey",
         start: "top 70%"
       }
     });

     // GSAP Horizontal scroll for desktop
     const initScroll = () => {
        // Kill existing triggers to prevent duplicates on resize
        ScrollTrigger.getAll().forEach(t => {
            if(t.vars.trigger === "#math-journey") t.kill();
        });

        if (window.innerWidth >= 768) {
          gsap.to(wrapper, {
            x: () => -(wrapper.scrollWidth - window.innerWidth) + "px",
            ease: "none",
            scrollTrigger: {
              trigger: "#math-journey",
              pin: true,
              scrub: 1,
              end: () => "+=" + (wrapper.scrollWidth - window.innerWidth)
            }
          });
        } else {
            // Reset transforms for mobile
            gsap.set(wrapper, { x: 0 });
        }
     };

     // Initial setup
     setTimeout(initScroll, 100);

     // Re-calculate on resize
     let resizeTimer: any;
     window.addEventListener("resize", () => {
         clearTimeout(resizeTimer);
         resizeTimer = setTimeout(initScroll, 250);
     });
  });
</script>

<style>
  @media (max-width: 768px) {
    .math-scroll-wrapper {
      flex-direction: column;
      height: auto !important;
      width: 100% !important;
    }
    #math-journey {
      height: auto !important;
      min-height: auto !important;
    }
    .math-formula {
      padding: 4rem 0;
      white-space: normal;
      flex-wrap: wrap;
      justify-content: center;
      line-height: 1.5;
    }
  }
</style>
