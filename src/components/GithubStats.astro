        border: 1px solid #30363d;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
        background: transparent;
        overflow: hidden;
      }

      .gh-org-pills-row {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #21262d;
      }

      .gh-activity-body {
        padding: 1.5rem;
        display: grid;
        grid-template-columns: 1fr auto 220px;
        gap: 0;
        align-items: center;
      }

      @media (max-width: 850px) {
        .gh-activity-body {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .gh-activity-sep {
          display: none;
        }
      }

      .gh-activity-left {
        padding-right: 2rem;
      }

      .gh-activity-sep {
        width: 1px;
        height: 140px;
        background: #21262d;
      }

      .gh-activity-title {
        font-size: 1rem;
        font-weight: 400;
        color: #e6edf3;
        margin: 0 0 1rem;
      }

      .gh-contributed-to {
        display: flex;
        gap: 0.8rem;
        align-items: flex-start;
        font-size: 0.85rem;
        color: #8b949e;
        line-height: 1.8;
      }

      .gh-contrib-icon {
        color: #8b949e;
        flex-shrink: 0;
        margin-top: 4px;
      }

      .gh-link {
        color: #58a6ff;
        text-decoration: none;
        font-weight: 600;
      }

      .gh-link:hover {
        text-decoration: underline;
      }

      .gh-org-pills {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      .gh-org-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.8rem;
        border: 1px solid #30363d;
        border-radius: 6px;
        font-size: 0.75rem;
        color: #e6edf3;
        text-decoration: none;
        font-weight: 600;
        background: #0d1117;
        transition: all 0.2s;
        white-space: nowrap;
      }

      .gh-org-pill:hover {
        border-color: #58a6ff;
        background: #161b22;
      }

      .gh-org-pill img {
        border-radius: 2px;
        flex-shrink: 0;
      }

      .gh-org-more {
        background: #161b22;
        border-color: #30363d;
        color: #8b949e;
        cursor: pointer;
      }

      .gh-activity-chart {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        padding-left: 2rem;
      }

      .gh-donut {
        opacity: 0.9;
        transition: opacity 0.3s;
        max-width: 100%;
        height: auto;
      }

      .gh-donut:hover {
        opacity: 1;
      }

      /* ===== SCROLL-IN ANIMATIONS ===== */
      .gh-profile-layout,
      .gh-contributions,
      .gh-activity-overview {
        opacity: 0;
        transform: translateY(30px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
      }

      .gh-profile-layout.gh-visible,
      .gh-contributions.gh-visible,
      .gh-activity-overview.gh-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <script>
      // Simple Intersection Observer for scroll-in animations
      document.addEventListener("DOMContentLoaded", () => {
        const targets = document.querySelectorAll(
          ".gh-profile-layout, .gh-contributions, .gh-activity-overview",
        );

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("gh-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 },
        );

        targets.forEach((t) => observer.observe(t));
      });
    </script>
  </div>
</section>
