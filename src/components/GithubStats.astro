---
/**
 * Interactive GSAP horizontal scrolling Math section.
 */
---

<section id="math-journey" class="relative z-10 bg-transparent min-h-screen w-full overflow-hidden flex items-center">
  
  <div class="math-scroll-wrapper flex items-center gap-10 md:gap-20 px-10 md:px-[10vw] h-full w-max flex-nowrap py-20 md:py-0">
    
    <!-- Title Area (First Slide) -->
    <div class="w-full md:w-[80vw] md:max-w-4xl flex-shrink-0 flex flex-col justify-center">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-[1px] w-12 bg-white/50"></div>
        <span class="text-xs font-bold tracking-widest text-white/80 uppercase">Deep Learning</span>
      </div>
      <h2 class="text-5xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-8" id="math-title">
        <div class="overflow-hidden"><span class="block title-line translate-y-full text-white/10">CLIPPED</span></div>
        <div class="overflow-hidden"><span class="block title-line translate-y-full text-white/40">OBJECTIVE</span></div>
      </h2>
      <p class="text-white/60 text-lg md:text-xl max-w-lg leading-relaxed font-medium">
        The massive GRPO / PPO Clipped Objective function. Scroll horizontally to explore the intricate mathematics of advanced AI reasoning and backpropagation.
      </p>
    </div>

    <!-- The Massive Formula -->
    <div class="flex-shrink-0 flex items-center">
       <div class="math-formula flex items-center text-[3rem] md:text-[6rem] font-serif italic text-white whitespace-nowrap tracking-tight">
          
          <!-- L_GRPO (θ) = - -->
          <div class="flex items-center mr-6 md:mr-10">
            <span class="drop-shadow-[0_0_20px_rgba(255,255,255,0.2)]">L</span>
            <span class="text-[1rem] md:text-[2rem] translate-y-4 md:translate-y-8 -ml-2 font-sans mr-3 font-bold text-white/70 tracking-widest">GRPO</span>
            <span class="font-sans">(</span>&theta;<span class="font-sans">)</span>
            <span class="text-white/50 mx-4 font-sans">=</span>
            <span class="text-white/50 font-sans -mr-2">-</span>
          </div>

          <!-- 1/G \sum_{i=1}^G -->
          <div class="flex items-center gap-4 mr-6 md:mr-10">
            <div class="flex flex-col items-center justify-center font-sans">
              <div class="text-[1.5rem] md:text-[3rem] leading-none mb-1">1</div>
              <div class="w-full h-[2px] bg-white/50 rounded-full"></div>
              <div class="text-[1.5rem] md:text-[3rem] leading-none mt-1 font-serif italic text-white/80">G</div>
            </div>
            
            <div class="flex flex-col items-center justify-center translate-y-1 md:translate-y-2 mx-2">
              <span class="text-[0.8rem] md:text-[1.5rem] leading-none text-white/60 mb-1 font-serif italic">G</span>
              <span class="text-[3rem] md:text-[8rem] leading-none font-sans text-white/80">&sum;</span>
              <span class="text-[0.8rem] md:text-[1.5rem] leading-none text-white/60 mt-1 font-sans">i=1</span>
            </div>
          </div>

          <!-- 1/|o_i| \sum_{t=1}^{|o_i|} -->
          <div class="flex items-center gap-4 mr-6 md:mr-10">
            <div class="flex flex-col items-center justify-center font-sans">
              <div class="text-[1.5rem] md:text-[3rem] leading-none mb-1">1</div>
              <div class="w-full h-[2px] bg-white/50 rounded-full"></div>
              <div class="text-[1.5rem] md:text-[3rem] leading-none mt-1 font-sans flex items-center">|o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 font-serif italic">i</span>|</div>
            </div>
            
            <div class="flex flex-col items-center justify-center translate-y-1 md:translate-y-2 mx-2">
              <span class="text-[0.8rem] md:text-[1.5rem] leading-none text-white/60 mb-1 font-sans flex items-center">|o<span class="text-[0.6rem] md:text-[1rem] translate-y-1 font-serif italic">i</span>|</span>
              <span class="text-[3rem] md:text-[8rem] leading-none font-sans text-white/80">&sum;</span>
              <span class="text-[0.8rem] md:text-[1.5rem] leading-none text-white/60 mt-1 font-sans">t=1</span>
            </div>
          </div>
          
          <!-- [ min( -->
          <span class="text-white/30 mx-2 md:mx-4 text-[4rem] md:text-[10rem] font-sans font-light translate-y-1">[</span>
          <span class="font-sans font-bold text-white/80 mr-4 tracking-widest">min</span>
          <span class="font-sans font-light text-white/50 mx-2 text-[4rem] md:text-[10rem] translate-y-1">(</span>
          
          <!-- Fraction 1 -->
          <div class="flex flex-col items-center justify-center mx-4 md:mx-6">
            <div class="flex items-center text-[2rem] md:text-[4rem]">
               <span class="font-sans">&pi;</span><span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4">&theta;</span>
               <span class="font-sans mx-1">(</span>o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans">i,t</span>
               <span class="font-sans mx-2 text-white/40">|</span>
               q, o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans text-white/80">i,&lt;t</span><span class="font-sans mx-1">)</span>
            </div>
            <div class="w-full h-[2px] bg-white/50 rounded-full my-3"></div>
            <div class="flex items-center text-[2rem] md:text-[4rem] text-white/70">
               <span class="font-sans">&pi;</span>
               <div class="flex flex-col items-center -ml-1 translate-y-3 md:translate-y-6">
                  <span class="text-[0.8rem] md:text-[1.5rem] leading-none">&theta;</span>
                  <span class="text-[0.5rem] md:text-[1rem] font-sans font-normal leading-none mt-1">old</span>
               </div>
               <span class="font-sans mx-1">(</span>o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans">i,t</span>
               <span class="font-sans mx-2 text-white/40">|</span>
               q, o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans text-white/60">i,&lt;t</span><span class="font-sans mx-1">)</span>
            </div>
          </div>
          
          <!-- A_hat_i,t , -->
          <div class="flex items-center mr-6 md:mr-10">
            <div class="flex flex-col items-center justify-center">
              <span class="text-[1.5rem] md:text-[3rem] leading-none translate-y-2 md:translate-y-4 font-sans text-white/60">^</span>
              <span class="text-[2.5rem] md:text-[5rem] leading-none font-sans drop-shadow-[0_0_20px_rgba(255,255,255,0.2)]">A</span>
            </div>
            <span class="text-[1rem] md:text-[2rem] translate-y-5 md:translate-y-8 font-sans text-white/80">i,t</span>
            <span class="font-sans text-white/50 translate-y-2 md:translate-y-4 ml-2">,</span>
          </div>
          
          <!-- clip( ... ) -->
          <span class="font-sans font-bold text-white/80 mr-4 tracking-widest ml-4">clip</span>
          <span class="font-sans font-light text-white/50 mx-2 text-[4rem] md:text-[10rem] translate-y-1">(</span>

          <!-- Fraction 2 -->
          <div class="flex flex-col items-center justify-center mx-4 md:mx-6">
            <div class="flex items-center text-[2rem] md:text-[4rem]">
               <span class="font-sans">&pi;</span><span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4">&theta;</span>
               <span class="font-sans mx-1">(</span>o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans">i,t</span>
               <span class="font-sans mx-2 text-white/40">|</span>
               q, o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans text-white/80">i,&lt;t</span><span class="font-sans mx-1">)</span>
            </div>
            <div class="w-full h-[2px] bg-white/50 rounded-full my-3"></div>
            <div class="flex items-center text-[2rem] md:text-[4rem] text-white/70">
               <span class="font-sans">&pi;</span>
               <div class="flex flex-col items-center -ml-1 translate-y-3 md:translate-y-6">
                  <span class="text-[0.8rem] md:text-[1.5rem] leading-none">&theta;</span>
                  <span class="text-[0.5rem] md:text-[1rem] font-sans font-normal leading-none mt-1">old</span>
               </div>
               <span class="font-sans mx-1">(</span>o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans">i,t</span>
               <span class="font-sans mx-2 text-white/40">|</span>
               q, o<span class="text-[0.8rem] md:text-[1.5rem] translate-y-2 md:translate-y-4 font-sans text-white/60">i,&lt;t</span><span class="font-sans mx-1">)</span>
            </div>
          </div>
          
          <span class="font-sans text-white/50 mx-4">,</span>
          <span class="font-sans text-white/80">1</span>
          <span class="font-sans text-white/50 mx-2">-</span>
          <span class="font-sans text-[#cccccc]">&epsilon;</span>
          
          <span class="font-sans text-white/50 mx-4">,</span>
          <span class="font-sans text-white/80">1</span>
          <span class="font-sans text-white/50 mx-2">+</span>
          <span class="font-sans text-[#cccccc]">&epsilon;</span>
          
          <span class="font-sans font-light text-white/50 mx-2 text-[4rem] md:text-[10rem] translate-y-1">)</span>

          <!-- A_hat_i,t ) -->
          <div class="flex items-center ml-4 mr-2">
            <div class="flex flex-col items-center justify-center">
              <span class="text-[1.5rem] md:text-[3rem] leading-none translate-y-2 md:translate-y-4 font-sans text-white/60">^</span>
              <span class="text-[2.5rem] md:text-[5rem] leading-none font-sans drop-shadow-[0_0_20px_rgba(255,255,255,0.2)]">A</span>
            </div>
            <span class="text-[1rem] md:text-[2rem] translate-y-5 md:translate-y-8 font-sans text-white/80">i,t</span>
          </div>
          <span class="font-sans font-light text-white/50 mx-2 text-[4rem] md:text-[10rem] translate-y-1">)</span>

          <!-- - beta D_KL [...] ] -->
          <span class="text-white/50 mx-6 md:mx-10 font-sans">-</span>
          <span class="text-[3rem] md:text-[6rem] font-sans text-[#cccccc]">&beta;</span>
          
          <div class="flex items-center mx-4 md:mx-8">
             <span class="font-sans mr-2 text-[3rem] md:text-[6rem]">D</span>
             <span class="text-[1rem] md:text-[2rem] translate-y-4 md:translate-y-6 font-sans font-bold tracking-widest text-white/60">KL</span>
          </div>
          
          <span class="text-white/30 mx-2 md:mx-4 text-[4rem] md:text-[10rem] font-sans font-light translate-y-1">[</span>
          
          <div class="flex items-center mx-4">
             <span class="font-sans text-[2.5rem] md:text-[5rem]">&pi;</span><span class="text-[1rem] md:text-[2rem] translate-y-4 md:translate-y-8">&theta;</span>
             <span class="text-white/40 font-sans mx-6 md:mx-8">||</span>
             <span class="font-sans text-[2.5rem] md:text-[5rem]">&pi;</span><span class="text-[1rem] md:text-[2rem] translate-y-4 md:translate-y-8 font-sans font-bold text-white/60 tracking-widest">ref</span>
          </div>
          
          <span class="text-white/30 mx-2 md:mx-4 text-[4rem] md:text-[10rem] font-sans font-light translate-y-1">]</span>
          <span class="text-white/30 mx-2 md:mx-4 text-[4rem] md:text-[10rem] font-sans font-light translate-y-1">]</span>
       </div>
    </div>
    
    <!-- End Spacer to allow smooth transition -->
    <div class="w-[30vw] flex-shrink-0"></div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
     const wrapper = document.querySelector('.math-scroll-wrapper') as HTMLElement;
     if (!wrapper) return;
     
     // Animate Title
     gsap.to('.title-line', {
       y: 0,
       duration: 1,
       stagger: 0.2,
       ease: "power4.out",
       scrollTrigger: {
         trigger: "#math-journey",
         start: "top 70%"
       }
     });

     // GSAP Horizontal scroll for desktop
     const initScroll = () => {
        // Kill existing triggers to prevent duplicates on resize
        ScrollTrigger.getAll().forEach(t => {
            if(t.vars.trigger === "#math-journey") t.kill();
        });

        if (window.innerWidth >= 768) {
          gsap.to(wrapper, {
            x: () => -(wrapper.scrollWidth - window.innerWidth) + "px",
            ease: "none",
            scrollTrigger: {
              trigger: "#math-journey",
              pin: true,
              scrub: 1,
              end: () => "+=" + (wrapper.scrollWidth - window.innerWidth)
            }
          });
        } else {
            // Reset transforms for mobile
            gsap.set(wrapper, { x: 0 });
        }
     };

     // Initial setup
     setTimeout(initScroll, 100);

     // Re-calculate on resize
     let resizeTimer: any;
     window.addEventListener("resize", () => {
         clearTimeout(resizeTimer);
         resizeTimer = setTimeout(initScroll, 250);
     });
  });
</script>

<style>
  @media (max-width: 768px) {
    .math-scroll-wrapper {
      flex-direction: column;
      height: auto !important;
      width: 100% !important;
    }
    #math-journey {
      height: auto !important;
      min-height: auto !important;
    }
    .math-formula {
      padding: 4rem 0;
      white-space: normal;
      flex-wrap: wrap;
      justify-content: center;
      line-height: 1.5;
    }
  }
</style>
