---

---

<section
  id="home"
  class="hero-section relative overflow-hidden select-none"
  style="min-height: 120vh;"
>
  <div class="dev-badge-corner">
    <span class="pulse-dot"></span>
    Portfolio Under Development
  </div>

  <!-- Ambient glow blobs -->
  <div class="hero-blob blob-blue"></div>
  <div class="hero-blob blob-cyan"></div>

  <div
    class="container z-10 flex items-center justify-center"
    style="min-height: 100vh; margin-top: -5vh;"
  >
    <div class="background-symbols">
      <span class="symbol top-left cream">&#123;</span>
      <span class="symbol top-right cream">&#125;</span>
    </div>

    <div
      class="flex flex-col md:flex-row items-center justify-center w-full gap-12 md:gap-20"
    >
      <!-- Profile picture with floating ring -->
      <div class="profile-picture-wrapper" id="profile-pic">
        <div class="profile-ring"></div>
        <div class="profile-picture">
          <img
            src="/profile.jpg"
            alt="Arsh Pathan"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Floating tech particles around profile -->
        <div class="profile-particles">
          <span class="pp" style="--angle: 0deg; --delay: 0s;">⟨/⟩</span>
          <span class="pp" style="--angle: 60deg; --delay: 0.5s;">λ</span>
          <span class="pp" style="--angle: 120deg; --delay: 1s;">{}</span>
          <span class="pp" style="--angle: 180deg; --delay: 1.5s;">∞</span>
          <span class="pp" style="--angle: 240deg; --delay: 2s;">⚡</span>
          <span class="pp" style="--angle: 300deg; --delay: 2.5s;">◈</span>
        </div>
      </div>

      <div class="text-content text-center md:text-left">
        <h1
          class="hero-name mb-4 flex flex-col justify-center md:items-start items-center"
          id="hero-name"
        >
          <span
            class="text-lg md:text-2xl text-text-muted font-medium mb-2 hero-greeting"
            id="hero-greeting">Hi, I am</span
          >
          <div class="relative w-fit hero-name-main" id="name-container">
            <span
              class="text-6xl md:text-8xl font-black tracking-tight text-text-main"
              id="typewriter-name">ARSH PATHAN</span
            >
            <div class="name-underline"></div>
          </div>
        </h1>

        <div
          class="subtitle-wrapper mb-10 h-8 md:h-12 flex items-center justify-center md:justify-start"
          id="role-container"
        >
          <span
            class="text-xl md:text-3xl text-text-muted font-bold mr-2 opacity-0"
            id="role-prefix">I am</span
          >
          <span
            class="text-xl md:text-3xl text-accent-gold font-bold"
            id="typewriter-role"></span>
          <span
            class="cursor-role h-6 md:h-10 w-0.5 md:w-1 bg-accent-gold ml-1"
            id="cursor-role"></span>
        </div>

        <!-- Stats row -->
        <div class="hero-stats" id="hero-stats">
          <div class="stat-item">
            <span class="stat-number" data-target="20">0</span>
            <span class="stat-label">Projects</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-target="5">0</span>
            <span class="stat-label">Years Coding</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number" data-target="10">0</span>
            <span class="stat-label">Technologies</span>
          </div>
        </div>

        <div
          class="flex gap-4 flex-wrap justify-center md:justify-start mt-8"
          id="hero-cta"
        >
          <a href="#contact" class="btn btn-primary btn-glow">
            <span>Get In Touch</span>
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <a href="#projects" class="btn btn-outline">
            <span>View Projects</span>
          </a>
        </div>
      </div>
    </div>

    <div class="scroll-indicator absolute bottom-10 left-1/2 -translate-x-1/2">
      <div class="scroll-mouse">
        <div class="scroll-wheel"></div>
      </div>
      <span class="scroll-text">Scroll Down</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const roles = [
    "A Developer",
    "A Student",
    "A Creator",
    "Founder of CSky Developments",
    "An AI Orchestration Developer",
    "A Problem Solver",
    "A Tech Enthusiast",
    "A Full-Stack Developer",
    "A Web Architect",
    "An Automation Builder",
    "An Open Source Contributor",
    "A Software Engineer",
    "A UI/UX Explorer",
    "A Startup Builder",
    "A System Designer",
    "A Backend Engineer",
    "A Frontend Craftsman",
    "A Debugging Ninja",
    "A Lifelong Learner",
    "A Performance Optimizer",
    "A Cloud Explorer",
    "A Code Simplifier",
    "A Digital Innovator",
  ];

  const addHangFallToElement = (element: HTMLElement) => {
    if (!element) return;

    element.style.cursor = "pointer";
    element.style.display = "inline-block";
    let state = 0;

    element.addEventListener("click", () => {
      if (state === 0) {
        gsap.to(element, {
          rotation: Math.random() < 0.5 ? 15 : -15,
          y: 5,
          transformOrigin: "top left",
          duration: 1.5,
          ease: "elastic.out(1, 0.4)",
        });
        state = 1;
      } else if (state === 1) {
        gsap.to(element, {
          y: 600,
          rotation: Math.random() * 180 - 90,
          opacity: 0,
          duration: 1,
          ease: "power2.in",
          onComplete: () => {
            setTimeout(
              () => {
                gsap.set(element, {
                  y: 0,
                  rotation: 0,
                  opacity: 1,
                  scale: 1,
                });
                state = 0;
              },
              2000 + Math.random() * 1000,
            );
          },
        });
        state = 2;
      }
    });
  };

  const typeEffect = (elementId: string, text: string, speed: number = 100) => {
    return new Promise((resolve) => {
      const element = document.getElementById(elementId);
      if (!element) return resolve(null);

      let i = 0;
      element.innerText = "";

      const typeChar = () => {
        if (i < text.length) {
          const char = text.charAt(i);
          const span = document.createElement("span");

          if (char === " ") {
            span.innerHTML = "&nbsp;";
          } else {
            span.innerText = char;
            addHangFallToElement(span);
          }

          element.appendChild(span);
          i++;
          setTimeout(typeChar, speed);
        } else {
          resolve(null);
        }
      };
      typeChar();
    });
  };

  const deleteEffect = (elementId: string, speed: number = 50) => {
    return new Promise((resolve) => {
      const element = document.getElementById(elementId);
      if (!element) return resolve(null);

      const deleteChar = () => {
        if (element.lastChild) {
          element.removeChild(element.lastChild);
          setTimeout(deleteChar, speed);
        } else {
          resolve(null);
        }
      };
      deleteChar();
    });
  };

  const startTypingRoles = async () => {
    let roleIndex = 0;
    while (true) {
      const currentRole = roles[roleIndex];
      await typeEffect("typewriter-role", currentRole, 100);
      await new Promise((r) => setTimeout(r, 2000));
      await deleteEffect("typewriter-role", 50);
      await new Promise((r) => setTimeout(r, 500));
      roleIndex = (roleIndex + 1) % roles.length;
    }
  };

  const makeTextInteractive = (elementId: string) => {
    const element = document.getElementById(elementId);
    if (!element) return;

    const text = element.innerText;
    element.innerText = "";

    text.split("").forEach((char) => {
      const span = document.createElement("span");
      if (char === " ") {
        span.innerHTML = "&nbsp;";
      } else {
        span.innerText = char;
        addHangFallToElement(span);
      }
      element.appendChild(span);
    });
  };

  const animateStats = () => {
    document.querySelectorAll(".stat-number").forEach((el) => {
      const target = parseInt(el.getAttribute("data-target") || "0");
      const obj = { value: 0 };
      gsap.to(obj, {
        value: target,
        duration: 2,
        delay: 1.5,
        ease: "power2.out",
        onUpdate: () => {
          el.textContent = Math.round(obj.value) + "+";
        },
      });
    });
  };

  // Run hero intro after manifesto
  const runHeroIntro = () => {
    const tl = gsap.timeline({ delay: 0.3 });

    tl.from("#profile-pic", {
      scale: 0.6,
      opacity: 0,
      filter: "blur(20px)",
      duration: 1.2,
      ease: "power3.out",
    })
      .to(
        "#hero-greeting",
        {
          opacity: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.6",
      )
      .from(
        "#name-container",
        {
          y: 60,
          opacity: 0,
          filter: "blur(15px)",
          duration: 1,
          ease: "power3.out",
          onComplete: () => {
            makeTextInteractive("typewriter-name");
          },
        },
        "-=0.4",
      )
      .to(
        "#role-prefix",
        { opacity: 1, duration: 0.5, ease: "power2.out" },
        "-=0.3",
      )
      .from(
        "#hero-stats",
        {
          y: 30,
          opacity: 0,
          filter: "blur(10px)",
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.2",
      )
      .from(
        "#hero-cta",
        {
          y: 40,
          opacity: 0,
          filter: "blur(10px)",
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.4",
      );

    startTypingRoles();
    animateStats();
  };

  document.addEventListener("DOMContentLoaded", () => {
    // Set initial states
    gsap.set("#hero-greeting", { opacity: 0, y: 20, filter: "blur(10px)" });
    gsap.set("#role-prefix", { opacity: 0 });

    window.addEventListener("manifestoComplete", runHeroIntro);

    if (sessionStorage.getItem("manifestoPlayed")) {
      runHeroIntro();
    }

    // Hero parallax on scroll
    gsap.to("#profile-pic", {
      y: -80,
      scrollTrigger: {
        trigger: "#home",
        start: "top top",
        end: "bottom top",
        scrub: 1,
      },
    });

    gsap.to(".text-content", {
      y: -40,
      scrollTrigger: {
        trigger: "#home",
        start: "top top",
        end: "bottom top",
        scrub: 1,
      },
    });

    gsap.to(".background-symbols", {
      y: 100,
      scrollTrigger: {
        trigger: "#home",
        start: "top top",
        end: "bottom top",
        scrub: 1,
      },
    });
  });
</script>

<style>
  .hero-section {
    position: relative;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  .blob-blue {
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      rgba(59, 130, 246, 0.08),
      transparent 70%
    );
    top: 10%;
    left: -5%;
    animation: blob-drift 12s ease-in-out infinite alternate;
  }

  .blob-cyan {
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(6, 182, 212, 0.06),
      transparent 70%
    );
    bottom: 15%;
    right: -5%;
    animation: blob-drift 15s ease-in-out infinite alternate-reverse;
  }

  @keyframes blob-drift {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(30px, -20px) scale(1.1);
    }
  }

  .profile-picture-wrapper {
    position: relative;
    width: 300px;
    height: 300px;
    flex-shrink: 0;
  }

  .profile-ring {
    position: absolute;
    inset: -15px;
    border-radius: 50%;
    border: 2px solid transparent;
    border-top-color: #3b82f6;
    border-right-color: #06b6d4;
    animation: ring-spin 8s linear infinite;
    opacity: 0.5;
  }

  @keyframes ring-spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  .profile-particles {
    position: absolute;
    inset: -40px;
    pointer-events: none;
  }

  .pp {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: 14px;
    font-weight: 700;
    color: #3b82f6;
    opacity: 0.3;
    font-family: "JetBrains Mono", monospace;
    animation: orbit 12s linear infinite;
    animation-delay: var(--delay);
    --orbit-radius: 170px;
    transform-origin: 0 0;
  }

  @keyframes orbit {
    0% {
      transform: rotate(var(--angle)) translateX(var(--orbit-radius))
        rotate(calc(-1 * var(--angle)));
    }
    100% {
      transform: rotate(calc(var(--angle) + 360deg))
        translateX(var(--orbit-radius))
        rotate(calc(-1 * (var(--angle) + 360deg)));
    }
  }

  @media (max-width: 768px) {
    .profile-picture-wrapper {
      width: 250px;
      height: 250px;
    }
    .pp {
      --orbit-radius: 140px;
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .profile-picture-wrapper {
      width: 200px;
      height: 200px;
    }
    .pp {
      --orbit-radius: 120px;
    }
  }

  .dev-badge-corner {
    position: absolute;
    top: 90px;
    right: 28px;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: #7dd3fc;
    background: rgba(56, 189, 248, 0.08);
    border: 1px solid rgba(56, 189, 248, 0.35);
    border-radius: 999px;
    backdrop-filter: blur(10px);
    box-shadow: 0 0 18px rgba(56, 189, 248, 0.15);
  }

  .pulse-dot {
    width: 10px;
    height: 10px;
    background: #38bdf8;
    border-radius: 50%;
    position: relative;
  }

  .pulse-dot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #38bdf8;
    animation: pulse-ring 1.6s infinite;
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(1);
      opacity: 0.9;
    }
    70% {
      transform: scale(2.8);
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .dev-badge-corner {
      top: 70px;
      right: 14px;
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  .profile-picture {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.15);
    background: #f5f0e6;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(59, 130, 246, 0.1);
    animation: morph 8s ease-in-out infinite;
  }

  @keyframes morph {
    0% {
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    }
    50% {
      border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
    }
    100% {
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    }
  }

  .name-underline {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #3b82f6, #06b6d4, #818cf8);
    transform: scaleX(0);
    transform-origin: left;
    animation: underline-reveal 1s ease 2s forwards;
    box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
  }

  @keyframes underline-reveal {
    to {
      transform: scaleX(1);
    }
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-stats {
      justify-content: flex-start;
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 900;
    color: #e8edf5;
    line-height: 1;
    font-family: "Outfit", sans-serif;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: #5a6d8a;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.3rem;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(59, 130, 246, 0.15);
  }

  /* Scroll indicator */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 20;
    padding-bottom: 80px;
    animation: fade-up-down 2s ease-in-out infinite;
  }

  .scroll-mouse {
    width: 24px;
    height: 38px;
    border: 2px solid rgba(96, 165, 250, 0.3);
    border-radius: 12px;
    position: relative;
  }

  .scroll-wheel {
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 8px;
    background: #60a5fa;
    border-radius: 3px;
    animation: scroll-wheel 2s ease-in-out infinite;
  }

  @keyframes scroll-wheel {
    0%,
    100% {
      opacity: 1;
      top: 6px;
    }
    50% {
      opacity: 0.3;
      top: 20px;
    }
  }

  .scroll-text {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #5a6d8a;
  }

  @keyframes fade-up-down {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: translateX(-50%) translateY(8px);
      opacity: 1;
    }
  }

  .btn-glow {
    position: relative;
  }

  .btn-glow::after {
    content: "";
    position: absolute;
    inset: -2px;
    background: linear-gradient(135deg, #3b82f6, #06b6d4);
    border-radius: inherit;
    z-index: -1;
    filter: blur(12px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .btn-glow:hover::after {
    opacity: 0.5;
  }

  .background-symbols {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .cream {
    color: rgba(95, 153, 223, 0.15);
  }

  .symbol {
    position: absolute;
    font-family: "Outfit", monospace;
    font-weight: 700;
    font-size: 15rem;
    line-height: 1;
    user-select: none;
    animation: float 6s ease-in-out infinite;
  }

  @media (max-width: 1024px) {
    .symbol {
      font-size: 10rem;
    }
  }

  @media (max-width: 768px) {
    .symbol {
      font-size: 6rem;
    }
    .top-left {
      top: 5rem;
      left: 1rem;
    }
    .top-right {
      top: 10rem;
      right: 1rem;
    }
  }

  .top-left {
    top: 2rem;
    left: 2rem;
  }
  .top-right {
    top: 25rem;
    right: 2rem;
  }

  @keyframes float {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .cursor-main,
  .cursor-role {
    animation: blink 1s step-end infinite;
  }
</style>
