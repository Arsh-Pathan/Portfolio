        <h3
          id="modal-title"
          class="text-4xl md:text-5xl font-black mb-6 text-white tracking-tighter"
        >
          Project Title
        </h3>
        <p
          id="modal-desc"
          class="text-text-secondary text-lg leading-relaxed mb-10 flex-grow font-medium"
        >
          Description goes here...
        </p>
        <div class="flex flex-wrap gap-4 mt-auto">
          <a
            id="modal-github"
            href="#"
            target="_blank"
            class="btn btn-outline flex items-center gap-2 group"
          >
            <svg
              class="w-5 h-5 group-hover:text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
            Repository
          </a>
          <a
            id="modal-website"
            href="#"
            target="_blank"
            class="btn btn-primary flex items-center gap-2 group"
          >
            Live Showcase
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const row1 = document.getElementById("projects-row-1");
    const row2 = document.getElementById("projects-row-2");
    const container = document.querySelector(".projects-section");

    if (row1 && row2 && container) {
      // Each row has cards duplicated 3x, so one "set" = 1/3 of scrollWidth
      const r1SetWidth = row1.scrollWidth / 3;
      const r2SetWidth = row2.scrollWidth / 3;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: ".projects-section",
          start: "top top",
          end: "+=700%", // Longer pin for plenty of time to explore
          pin: true,
          scrub: 3, // Very high scrub for incredibly soft smooth scrolling
          anticipatePin: 1,
          pinSpacing: true,
          invalidateOnRefresh: true,
        },
      });

      // Row 1 glides left by exactly one set (1/3 of the total triplicated width)
      tl.to(
        row1,
        {
          x: () => -(row1.scrollWidth / 3),
          ease: "none",
        },
        0,
      );

      // Row 2 starts shifted left by one set, and glides right to 0
      gsap.set(row2, { x: () => -(row2.scrollWidth / 3) });
      tl.to(
        row2,
        {
          x: 0,
          ease: "none",
        },
        0,
      );

      // Velocity-based skew for premium kinetic feel
      let lastScrollY = window.scrollY;
      let skewTimeout: any;

      window.addEventListener("scroll", () => {
        const velocity = window.scrollY - lastScrollY;
        const skewAmount = Math.min(Math.max(velocity * 0.08, -3), 3);

        gsap.to([row1, row2], {
          skewY: skewAmount,
          duration: 0.3,
          ease: "power2.out",
        });

        clearTimeout(skewTimeout);
        skewTimeout = setTimeout(() => {
          gsap.to([row1, row2], {
            skewY: 0,
            duration: 0.8,
            ease: "elastic.out(1, 0.3)",
          });
        }, 100);

        lastScrollY = window.scrollY;
      });

      window.addEventListener("load", () => {
        ScrollTrigger.refresh();
      });
    }

    // 3D tilt on project card hover
    document.querySelectorAll(".project-card").forEach((card) => {
      const el = card as HTMLElement;
      card.addEventListener("mousemove", (e: any) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) / 20;
        const rotateY = (centerX - x) / 20;

        gsap.to(card, {
          rotateX: rotateX,
          rotateY: rotateY,
          duration: 0.4,
          ease: "power2.out",
          transformPerspective: 800,
        });
      });

      card.addEventListener("mouseleave", () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.6,
          ease: "elastic.out(1, 0.3)",
        });
      });
    });

    // Modal logic (remains mostly same but updated selectors)
    const modal = document.getElementById("project-modal");
    const overlay = document.getElementById("modal-overlay");
    const closeBtn = document.getElementById("modal-close");
    const modalContent = document.getElementById("modal-content");
    const mTitle = document.getElementById("modal-title");
    const mDesc = document.getElementById("modal-desc");
    const mImage = document.getElementById("modal-image") as HTMLImageElement;
    const mTags = document.getElementById("modal-tags");
    const mGithub = document.getElementById(
      "modal-github",
    ) as HTMLAnchorElement;
    const mWebsite = document.getElementById(
      "modal-website",
    ) as HTMLAnchorElement;

    interface ProjectData {
      title: string;
      shortDesc: string;
      description: string;
      tags: string[];
      github: string;
      website: string;
      image: string;
    }

    function openModal(data: ProjectData) {
      if (!mTitle || !mDesc || !mImage || !mTags || !mGithub || !mWebsite)
        return;
      mTitle.innerText = data.title;
      mDesc.innerText = data.description;
      mImage.src = data.image;
      mImage.alt = data.title;
      mGithub.href = data.github || "#";
      mWebsite.href = data.website || "#";
      mTags.innerHTML = "";
      data.tags.forEach((tag) => {
        const span = document.createElement("span");
        span.className =
          "px-3 py-1 bg-accent-blue/10 text-accent-blue text-[10px] font-black uppercase tracking-widest rounded-full border border-accent-blue/20";
        span.innerText = tag;
        mTags.appendChild(span);
      });
      if (modal && modalContent) {
        modal.style.pointerEvents = "auto";
        modal.classList.remove("opacity-0");
        modalContent.classList.remove("scale-95");
        modalContent.classList.add("scale-100");
        document.body.style.overflow = "hidden";
      }
    }

    function closeModal() {
      if (modal && modalContent) {
        modal.classList.add("opacity-0");
        modal.style.pointerEvents = "none";
        modalContent.classList.remove("scale-100");
        modalContent.classList.add("scale-95");
        document.body.style.overflow = "";
      }
    }

    document.querySelectorAll(".project-card").forEach((card) => {
      card.addEventListener("click", () => {
        const json = card.getAttribute("data-json");
        if (json) openModal(JSON.parse(json));
      });
    });

    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (overlay) overlay.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  });
</script>

<style>
  .projects-section {
    background-color: #0a0f1c;
    background-image: radial-gradient(
      circle at 50% 50%,
      rgba(59, 130, 246, 0.03) 0%,
      transparent 100%
    );
    position: relative;
    z-index: 10;
  }

  .horizontal-scroll-container {
    overflow-x: hidden;
    width: 100%;
    position: relative;
    z-index: 20;
    /* Extra wide soft fade on left and right edges */
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 20%,
      black 80%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 20%,
      black 80%,
      transparent 100%
    );
  }

  #projects-row-1,
  #projects-row-2 {
    will-change: transform;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .project-card {
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  #modal-content::-webkit-scrollbar {
    width: 6px;
  }
  #modal-content::-webkit-scrollbar-track {
    background: transparent;
  }
  #modal-content::-webkit-scrollbar-thumb {
    background: #3b82f6;
    border-radius: 3px;
  }
</style>
