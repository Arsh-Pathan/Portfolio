---
/**
 * Professional, compact Projects section.
 * Designed to fit 6 projects in a responsive grid.
 */

const projects = [
  {
    title: 'AureX',
    description: 'A comprehensive mobile application built with React Native for managing curriculum activities and attendance.',
    tags: ['React Native', 'Mobile', 'Node.js', 'Expo'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1000&auto=format&fit=crop',
    year: '2025'
  },
  {
    title: 'CSkyCore',
    description: 'A high-performance Java backend infrastructure powering communities of thousands of concurrent users.',
    tags: ['Java', 'Game Dev', 'Redis', 'Netty'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1555949963-aa79dcee981c?q=80&w=1000&auto=format&fit=crop',
    year: '2024'
  },
  {
    title: 'CodeHost',
    description: 'A cloud platform-as-a-service allowing users to deploy and manage applications instantly via custom containers.',
    tags: ['Go', 'Cloud', 'Docker', 'K8s'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=1000&auto=format&fit=crop',
    year: '2026'
  },
  {
    title: 'LogicLab',
    description: 'Interactive digital logic simulator built on modern web technologies to teach computer architecture visually.',
    tags: ['TypeScript', 'WebGL', 'Canvas'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?q=80&w=1000&auto=format&fit=crop',
    year: '2025'
  },
  {
    title: 'NeuralNet',
    description: 'A custom deep learning framework written from scratch in C++ for educational and research purposes.',
    tags: ['C++', 'AI', 'CUDA', 'Math'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1000&auto=format&fit=crop',
    year: '2023'
  },
  {
    title: 'Nexus UI',
    description: 'A beautifully designed, accessible component library for modern React applications with a focus on animation.',
    tags: ['React', 'CSS', 'Framer Motion'],
    github: '#',
    website: '#',
    image: 'https://images.unsplash.com/photo-1507238692062-5a04238eb145?q=80&w=1000&auto=format&fit=crop',
    year: '2026'
  }
];
---

<section id="projects" class="py-32 relative z-10 bg-transparent perspective-[2000px]">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="h-[1px] w-8 bg-white/50"></div>
          <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Selected Work</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight project-heading opacity-0 translate-y-10">
          Featured <span class="text-white/40">Projects</span>
        </h2>
      </div>
      <a href="https://github.com/Arsh-Pathan" target="_blank" class="group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors">
        View full archive
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>

    <!-- 3 Column Grid for compactness -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 projects-grid preserve-3d">
      {projects.map((project, idx) => (
        <div class="project-card opacity-0 group/card block relative rounded-2xl bg-white/[0.01] backdrop-blur-sm border border-white/10 overflow-visible transition-all duration-700 hover:bg-white/[0.05] hover:border-white/30 preserve-3d transform-style-3d hover:z-50">
          
          <!-- Floating Tech Nodes -->
          <div class="absolute inset-0 z-10 pointer-events-none">
             {project.tags.map((tag, i) => (
                <div class={`absolute top-1/2 left-1/2 opacity-0 group-hover/card:opacity-100 transition-all duration-700 ease-[cubic-bezier(0.2,0.8,0.2,1)] tech-pos-${i}`}>
                   <div class={`animate-float-${i} px-4 py-2 bg-black/80 backdrop-blur-xl border border-white/20 rounded-full text-white/90 text-[10px] sm:text-xs font-mono font-bold tracking-widest whitespace-nowrap shadow-[0_0_30px_rgba(255,255,255,0.15)]`}>
                      {tag}
                   </div>
                </div>
             ))}
          </div>

          <!-- Card Content Wrapper -->
          <div class="relative z-20 w-full h-full rounded-2xl overflow-hidden shadow-2xl transition-all duration-700 group-hover/card:shadow-[0_0_80px_-20px_rgba(255,255,255,0.15)] group-hover/card:scale-[1.02]">

          <!-- Compact Image Container -->
          <div class="relative w-full h-[220px] overflow-hidden bg-transparent">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover opacity-50 saturate-0 group-hover:saturate-100 group-hover:opacity-90 group-hover:scale-110 transition-all duration-1000 ease-[cubic-bezier(0.2,0.8,0.2,1)]" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent pointer-events-none"></div>
            
            <div class="absolute top-4 right-4 px-3 py-1 bg-black/60 backdrop-blur-md rounded-full border border-white/20 text-[10px] font-bold tracking-widest text-white/70">
              {project.year}
            </div>
          </div>

          <!-- Compact Content Container -->
          <div class="relative p-6 md:p-8 -mt-12 bg-gradient-to-b from-transparent via-black/90 to-black flex flex-col h-[240px] translate-z-10">
            <h3 class="text-xl font-bold text-white mb-2 tracking-tight drop-shadow-md">{project.title}</h3>
            <p class="text-white/60 text-xs leading-relaxed mb-4 flex-grow">{project.description}</p>
            
            <div class="flex items-center justify-between mt-auto pt-4 border-t border-white/10">
              <div class="flex gap-2">
                {project.tags.slice(0, 2).map(tag => (
                  <span class="text-[10px] font-semibold tracking-wider uppercase text-white/40">{tag}</span>
                ))}
              </div>
              
              <div class="flex gap-2 relative z-20">
                <a href={project.github} target="_blank" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/20 flex items-center justify-center text-white/70 hover:text-white transition-all duration-300 border border-white/10 hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                </a>
                <a href={project.website} target="_blank" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/30 flex items-center justify-center text-white/90 hover:text-white transition-all duration-300 border border-white/30 hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                </a>
              </div>
            </div>
          </div>
          
          </div> <!-- End Card Content Wrapper -->
        </div>
      ))}
    </div>
    
  </div>
</section>

<style>
  .perspective-\[2000px\] {
    perspective: 2000px;
  }
  .preserve-3d {
    transform-style: preserve-3d;
  }
  .transform-style-3d {
    transform-style: preserve-3d;
  }
  .translate-z-10 {
    transform: translateZ(20px);
  }

  /* Grid Hover Dimming */
  .projects-grid:hover .project-card:not(:hover) {
    opacity: 0.2 !important;
    transform: scale(0.95) !important;
    filter: blur(2px) !important;
    transition: all 0.5s ease;
  }

  /* Tech Node Initial States */
  .tech-pos-0, .tech-pos-1, .tech-pos-2, .tech-pos-3 {
    transform: translate(-50%, -50%) scale(0.5);
  }

  /* Tech Node Hover States (Bursting Outwards) */
  .group\/card:hover .tech-pos-0 { transform: translate(-120%, -220%) scale(1); }
  .group\/card:hover .tech-pos-1 { transform: translate(50%, -180%) scale(1); }
  .group\/card:hover .tech-pos-2 { transform: translate(60%, 100%) scale(1); }
  .group\/card:hover .tech-pos-3 { transform: translate(-110%, 130%) scale(1); }

  /* Smooth Floating Animations */
  .animate-float-0 { animation: float-1 4s ease-in-out infinite alternate; }
  .animate-float-1 { animation: float-2 5s ease-in-out infinite alternate-reverse; }
  .animate-float-2 { animation: float-1 3.5s ease-in-out infinite alternate; }
  .animate-float-3 { animation: float-2 4.5s ease-in-out infinite alternate-reverse; }

  @keyframes float-1 {
    0% { transform: translateY(0px) rotate(0deg); }
    100% { transform: translateY(-20px) rotate(5deg); }
  }
  @keyframes float-2 {
    0% { transform: translateY(0px) rotate(0deg); }
    100% { transform: translateY(15px) rotate(-5deg); }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Heading animation
    gsap.to(".project-heading", {
      scrollTrigger: {
        trigger: "#projects",
        start: "top 80%",
      },
      y: 0,
      opacity: 1,
      duration: 1,
      ease: "power3.out"
    });

    // 3D Cards entrance from background space
    gsap.set(".project-card", {
      z: -800,
      opacity: 0,
      scale: 0.8
    });

    gsap.to(".project-card", {
      scrollTrigger: {
        trigger: ".projects-grid",
        start: "top 85%",
        end: "top 20%",
        scrub: 1.5,
      },
      z: 0,
      opacity: 1,
      scale: 1,
      ease: "power1.out",
      stagger: 0.1
    });

    // Add subtle continuous floating animation
    const cards = document.querySelectorAll('.project-card');
    cards.forEach((card, index) => {
      gsap.to(card, {
        y: "+=10",
        z: "+=15",
        duration: 3 + (index * 0.5),
        yoyo: true,
        repeat: -1,
        ease: "sine.inOut"
      });
    });
  });
</script>
