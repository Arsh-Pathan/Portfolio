---
/**
 * Professional, compact Projects section.
 * Designed to fit 6 projects in a responsive grid.
 */

const projects = [
  {
    title: 'Roamr',
    description: 'A high-performance Android travel app featuring offline mapping and smart trip planning via local Edge inference.',
    tags: ['Kotlin', 'Llama', 'Mobile'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=1000&auto=format&fit=crop',
    year: '2025'
  },
  {
    title: 'CodeHost',
    description: 'A cloud PaaS allowing developers to deploy full-stack apps instantly. Built with live terminal streams and Traefik reverse proxies.',
    tags: ['TypeScript', 'Cloud', 'Docker', 'PostgreSQL'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?q=80&w=1000&auto=format&fit=crop',
    year: '2024'
  },
  {
    title: 'LogicLab',
    description: 'High-precision digital logic laboratory simulator allowing engineers to render, trace, and package complex digital circuitry using a 3D overlay grid.',
    tags: ['React', 'WebGL', 'PostgreSQL'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?q=80&w=1000&auto=format&fit=crop',
    year: '2024'
  },
  {
    title: 'NeuralNetwork Framework',
    description: 'Dependency-free neural network system engineered from scratch in Java, supporting complete forward and backward mathematical propagation.',
    tags: ['Java', 'AI', 'Math'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=1000&auto=format&fit=crop',
    year: '2023'
  },
  {
    title: 'MaterialForge',
    description: 'A reinforcement learning environment where AI agents design crystalline atomic structures on an 8x8 lattice using Meta\'s OpenEnv framework.',
    tags: ['Python', 'AI', 'Cloud'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1507238692062-5a04238eb145?q=80&w=1000&auto=format&fit=crop',
    year: '2024'
  },
  {
    title: 'NeuroBoard',
    description: 'An AI canvas parsing sketches and solving complex handwritten math operations for real-time interactive pedagogy.',
    tags: ['React', 'AI', 'Python'],
    github: 'https://github.com/Arsh-Pathan',
    website: 'https://github.com/Arsh-Pathan',
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1000&auto=format&fit=crop',
    year: '2025'
  }
];

const techIconMap: Record<string, string> = {
  'Kotlin': 'kotlin/kotlin-original.svg',
  'Llama': 'python/python-original.svg',
  'Mobile': 'android/android-original.svg',
  'Node.js': 'nodejs/nodejs-original.svg',
  'Java': 'java/java-original.svg',
  'Redis': 'redis/redis-original.svg',
  'Cloud': 'googlecloud/googlecloud-original.svg',
  'Docker': 'docker/docker-original.svg',
  'TypeScript': 'typescript/typescript-original.svg',
  'WebGL': 'opengl/opengl-original.svg',
  'AI': 'python/python-original.svg',
  'Math': 'jupyter/jupyter-original.svg',
  'React': 'react/react-original.svg',
  'Python': 'python/python-original.svg',
  'PostgreSQL': 'postgresql/postgresql-original.svg',
};

const getIcon = (tag: string) => techIconMap[tag] || 'javascript/javascript-original.svg';
---

<section id="projects" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="h-[1px] w-8 bg-white/50"></div>
          <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Selected Work</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight project-heading opacity-0 translate-y-10">
          Featured <span class="text-white/40">Projects</span>
        </h2>
      </div>
      <a href="https://github.com/Arsh-Pathan" target="_blank" class="group flex items-center gap-2 text-sm font-medium text-white/80 hover:text-white transition-colors">
        View full archive
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
    </div>

    <!-- 3 Column Grid for compactness -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 projects-grid">
      {projects.map((project, idx) => (
        <div class="project-card opacity-0 group block relative rounded-2xl bg-white/[0.01] backdrop-blur-sm border border-white/10 overflow-visible transition-all duration-700 hover:bg-white/[0.05] hover:border-white/30 hover:z-50">
          
          <!-- Card Content Wrapper -->
          <div class="relative z-20 w-full h-full rounded-2xl overflow-hidden shadow-2xl transition-all duration-700 group-hover:shadow-[0_0_80px_-20px_rgba(255,255,255,0.15)] group-hover:scale-[1.02]">

          <!-- Compact Image Container -->
          <div class="relative w-full h-[220px] overflow-hidden bg-transparent">
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full object-cover opacity-50 saturate-0 group-hover:saturate-100 group-hover:opacity-90 group-hover:scale-110 transition-all duration-1000 ease-[cubic-bezier(0.2,0.8,0.2,1)]" 
              loading="lazy" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent pointer-events-none"></div>
            
            <div class="absolute top-4 right-4 px-3 py-1 bg-black/60 backdrop-blur-md rounded-full border border-white/20 text-[10px] font-bold tracking-widest text-white/70">
              {project.year}
            </div>
          </div>

          <!-- Compact Content Container -->
          <div class="relative p-6 md:p-8 -mt-12 bg-gradient-to-b from-transparent via-black/90 to-black flex flex-col h-[240px]">
            <h3 class="text-xl font-bold text-white mb-2 tracking-tight drop-shadow-md">{project.title}</h3>
            <p class="text-white/60 text-xs leading-relaxed mb-4 flex-grow">{project.description}</p>
            
            <div class="flex items-center justify-between mt-auto pt-4 border-t border-white/10">
              <div class="flex gap-2">
                {project.tags.slice(0, 2).map(tag => (
                  <span class="text-[10px] font-semibold tracking-wider uppercase text-white/40">{tag}</span>
                ))}
              </div>
              
              <div class="flex gap-2 relative z-20">
                <a href={project.github} target="_blank" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/20 flex items-center justify-center text-white/70 hover:text-white transition-all duration-300 border border-white/10 hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                </a>
                <a href={project.website} target="_blank" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/30 flex items-center justify-center text-white/90 hover:text-white transition-all duration-300 border border-white/30 hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                </a>
              </div>
            </div>
          </div>
          
          </div> <!-- End Card Content Wrapper -->

          <!-- Floating Tech Nodes (Microscope Labels) - NOW ON TOP -->
          <div class="absolute inset-0 z-50 pointer-events-none">
             {project.tags.map((tag, i) => {
                // Generate random position pushing towards edges (10% to 90%)
                const dx = (Math.random() * 2 - 1);
                const dy = (Math.random() * 2 - 1);
                
                // Push towards edges to avoid clustering in the center
                const pushX = dx > 0 ? Math.max(0.3, dx) : Math.min(-0.3, dx);
                const pushY = dy > 0 ? Math.max(0.3, dy) : Math.min(-0.3, dy);
                
                const originLeft = 50 + pushX * 40;
                const originTop = 50 + pushY * 40;
                
                // Base angle directly away from center
                const baseAngle = Math.atan2(pushY, pushX) * (180 / Math.PI);
                // Add up to 30 degrees of random variance
                const rotateLine = baseAngle + (Math.random() * 60 - 30);
                const rotateIcon = -rotateLine;

                return (
                <div 
                  class="absolute w-0 group-hover:w-[140px] md:group-hover:w-[180px] h-px bg-white/50 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] origin-left"
                  style={`top: ${originTop}%; left: ${originLeft}%; transform: rotate(${rotateLine}deg);`}
                >
                   <!-- Dot at the card edge -->
                   <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-white opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                   
                   <!-- Icon container at the far end -->
                   <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-full pl-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-150">
                      <div 
                        class="w-9 h-9 rounded-full bg-black/95 border border-white/20 backdrop-blur-md flex items-center justify-center p-1.5 shadow-[0_0_20px_rgba(255,255,255,0.15)] relative"
                        style={`transform: rotate(${rotateIcon}deg);`}
                      >
                          <img 
                            src={`https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/${getIcon(tag)}`} 
                            alt={tag} 
                            title={tag}
                            class="w-full h-full object-contain filter grayscale opacity-90 transition-opacity duration-300" 
                          />
                      </div>
                   </div>
                </div>
             )})}
          </div>

        </div>
      ))}
    </div>
    
  </div>
</section>

<style>
  /* Grid Hover Dimming */
  .projects-grid:hover .project-card:not(:hover) {
    opacity: 0.2 !important;
    filter: blur(2px) !important;
  }

  .project-card {
    transition: opacity 0.5s ease, filter 0.5s ease, transform 0.5s ease;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Heading animation
    gsap.to(".project-heading", {
      scrollTrigger: {
        trigger: "#projects",
        start: "top 80%",
      },
      y: 0,
      opacity: 1,
      duration: 1,
      ease: "power3.out"
    });

    // 3D Cards entrance from background space
    gsap.set(".project-card", {
      z: -800,
      opacity: 0,
      scale: 0.8
    });

    gsap.to(".project-card", {
      scrollTrigger: {
        trigger: ".projects-grid",
        start: "top 85%",
        end: "top 20%",
        scrub: 1.5,
      },
      z: 0,
      opacity: 1,
      scale: 1,
      ease: "power1.out",
      stagger: 0.1
    });

    // Add subtle continuous floating animation
    const cards = document.querySelectorAll('.project-card');
    cards.forEach((card, index) => {
      gsap.to(card, {
        y: "+=10",
        z: "+=15",
        duration: 3 + (index * 0.5),
        yoyo: true,
        repeat: -1,
        ease: "sine.inOut"
      });
    });
  });
</script>
