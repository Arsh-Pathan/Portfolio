  <div
    class="relative rounded-3xl w-[95vw] md:w-[900px] max-h-[90vh] overflow-y-auto shadow-2xl transform scale-95 transition-transform duration-300 flex flex-col border border-white/10"
    id="modal-content"
    style="background: #0d1427;"
  >
    <button
      id="modal-close"
      class="absolute top-6 right-6 z-20 p-3 bg-white/10 hover:bg-white/20 rounded-full transition-colors"
    >
      <svg
        class="w-6 h-6 text-white"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div class="flex flex-col md:flex-row h-full">
      <div class="w-full md:w-1/2 h-80 md:h-auto relative shrink-0">
        <img
          id="modal-image"
          src=""
          alt="Project Preview"
          class="w-full h-full object-cover"
        />
        <div
          class="absolute inset-0 bg-gradient-to-r from-transparent to-[#0d1427] hidden md:block"
        >
        </div>
        <div
          class="absolute inset-0 bg-gradient-to-t from-[#0d1427] to-transparent md:hidden"
        >
        </div>
      </div>

      <div class="w-full md:w-1/2 p-10 md:p-14 flex flex-col">
