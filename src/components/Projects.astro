---

<section
  id="projects"
  class="projects-section relative overflow-hidden bg-bg-primary min-h-[60vh] flex items-center"
>
  <div class="relative z-10 w-full py-12">
    <div class="container text-center mb-16">
      <h2 class="section-title">
