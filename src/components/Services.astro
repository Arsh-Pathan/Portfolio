---
const services = [
  {
    title: "AI & ML Architecture",
    description: "Designing intelligent systems, from predictive models to full-scale Generative AI agents. I build pipelines that turn raw data into strategic assets.",
    icon: "M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"
  },
  {
    title: "Startup Incubation",
    description: "Through CSky Developments, I help founders take their technical ideas from napkin sketches to deployed, scalable architectures.",
    icon: "m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"
  },
  {
    title: "High-Performance Backends",
    description: "Writing extremely fast, concurrent backend systems in Go, C++, and Python to handle millions of requests without breaking a sweat.",
    icon: "M2 22h20M2 2h20M6 6h.01M6 18h.01M18 6h.01M18 18h.01M12 2v20"
  }
];
---

<section id="services" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-8 bg-white/50"></div>
        <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">What I Do</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight">
        Services & <span class="text-white/40">Capabilities</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div class="service-card group relative p-10 bg-white/[0.02] border border-white/5 hover:border-white/20 rounded-3xl backdrop-blur-sm transition-all duration-500 overflow-hidden min-h-[350px] flex flex-col">
          
          <div class="absolute inset-0 bg-gradient-to-b from-white/[0.05] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-8 text-white/80 group-hover:scale-110 group-hover:text-white transition-all duration-500">
               <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                 <path d={service.icon}></path>
               </svg>
            </div>
            
            <h3 class="text-2xl font-bold text-white mb-4">{service.title}</h3>
            <p class="text-white/50 leading-relaxed text-sm md:text-base">
              {service.description}
            </p>
          </div>
          
          <div class="mt-auto pt-8 relative z-10">
            <span class="text-xs font-bold uppercase tracking-widest text-white/30 group-hover:text-white/80 transition-colors flex items-center gap-2">
              Learn More 
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </span>
          </div>
          
        </div>
      ))}
    </div>
    
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.from(".service-card", {
      scrollTrigger: {
        trigger: "#services",
        start: "top 75%",
      },
      y: 50,
      opacity: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out"
    });
  });
</script>
