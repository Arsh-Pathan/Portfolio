---
/**
 * Professional, founder-tier Skills section focused on AI/ML and Leadership.
 */
const categories = [
  {
    title: "Generative AI & LLMs",
    description: "Designing and deploying advanced Agentic AI systems, prompt engineering, and integrating large language models.",
    items: ["LangChain", "OpenAI API", "Agentic Systems", "RAG architectures", "Hugging Face"],
    icon: "brain",
  },
  {
    title: "Machine Learning Core",
    description: "Building, training, and fine-tuning neural networks for computer vision, NLP, and predictive analytics.",
    items: ["PyTorch", "TensorFlow", "Scikit-learn", "Pandas", "Model Optimization"],
    icon: "network",
  },
  {
    title: "Scalable Infrastructure",
    description: "Architecting robust backend systems capable of handling high-throughput ML inferences and real-time data.",
    items: ["Python", "C++", "Go", "AWS", "Docker", "Kubernetes"],
    icon: "server",
  },
  {
    title: "Leadership & Product",
    description: "Driving technical vision from zero to one. Leading engineering teams to deliver impactful software at CSky Developments.",
    items: ["Founder @ CSky", "System Design", "Product Strategy", "Open Source", "Team Leadership"],
    icon: "crown",
  }
];
---

<section id="skills" class="py-32 relative z-10 bg-transparent">
  <div class="container mx-auto px-6 max-w-7xl">
    
    <div class="mb-20">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-[1px] w-8 bg-white/50"></div>
        <span class="text-xs font-semibold tracking-widest text-white/80 uppercase">Core Competencies</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-medium text-white tracking-tight max-w-3xl leading-tight skill-heading">
        Bridging the gap between <span class="text-white/40">artificial intelligence</span> and scalable products.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {categories.map((cat, i) => (
        <div class="skill-card group relative p-8 md:p-10 bg-[#000000]/40 hover:bg-[#0a0a0a]/80 rounded-[24px] border border-white/5 hover:border-white/20 transition-all duration-500 overflow-hidden backdrop-blur-md flex flex-col h-full opacity-0 translate-y-10">
          
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-white/10 blur-[60px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          
          <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-8 text-white/80 group-hover:scale-110 group-hover:bg-white/10 transition-all duration-500">
            {cat.icon === "brain" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"></path><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"></path></svg>
            )}
            {cat.icon === "network" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
            )}
            {cat.icon === "server" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
            )}
            {cat.icon === "crown" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 4 3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"></path></svg>
            )}
          </div>

          <h3 class="text-xl font-medium text-white mb-3">{cat.title}</h3>
          <p class="text-[#8b949e] text-sm leading-relaxed mb-8 flex-grow">{cat.description}</p>
          
          <div class="flex flex-wrap gap-2">
            {cat.items.map(item => (
              <span class="px-3 py-1.5 bg-white/[0.03] border border-white/5 rounded-lg text-xs font-medium text-[#c9d1d9] hover:bg-white/10 transition-colors cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // Advanced text reveal for heading
    const heading = document.querySelector('.skill-heading');
    if (heading) {
      // Simple split text simulation for animation
      const text = heading.innerHTML;
      // We'll just animate the whole heading with a clipPath reveal
      gsap.from(heading, {
        scrollTrigger: {
          trigger: heading,
          start: "top 85%",
        },
        y: 40,
        opacity: 0,
        clipPath: "polygon(0 0, 100% 0, 100% 0%, 0% 0%)",
        duration: 1.2,
        ease: "power4.out"
      });
      gsap.to(heading, {
        scrollTrigger: {
          trigger: heading,
          start: "top 85%",
        },
        clipPath: "polygon(0 0, 100% 0, 100% 100%, 0% 100%)",
        duration: 1.2,
        ease: "power4.out"
      });
    }

    // Staggered card reveals
    gsap.to('.skill-card', {
      scrollTrigger: {
        trigger: ".grid",
        start: "top 85%",
      },
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.15,
      ease: "back.out(1.2)"
    });
  });
</script>
