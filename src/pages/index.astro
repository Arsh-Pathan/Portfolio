---
import "../styles/global.css";
import Background from "../components/Background.astro";
import Hero from "../components/Hero.astro";
import Skills from "../components/Skills.astro";
import GithubStats from "../components/GithubStats.astro";
import Projects from "../components/Projects.astro";
import Gallery from "../components/Gallery.astro";
import Manifesto from "../components/Manifesto.astro";
import Certificates from "../components/Certificates.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import CustomCursor from "../components/CustomCursor.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import NoiseOverlay from "../components/NoiseOverlay.astro";
import TextReveal from "../components/TextReveal.astro";
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Arsh Pathan — Developer, Creator, and Tech Enthusiast. Explore my portfolio of projects, skills, and achievements."
    />
    <meta name="theme-color" content="#060a14" />
    <meta property="og:title" content="Arsh Pathan — Portfolio" />
    <meta
      property="og:description"
      content="Developer, Creator, and Tech Enthusiast. Explore my portfolio of projects, skills, and achievements."
    />
    <meta property="og:type" content="website" />
    <title>Arsh Pathan — Developer & Creator</title>
  </head>
  <body class="bg-bg-primary text-text-main antialiased overflow-x-hidden">
    <Background />
    <NoiseOverlay />
    <CustomCursor />
    <Manifesto />
    <SmoothScroll />
    <TextReveal />

    <main id="main-content" class="relative z-10">
      <Hero />
      <Skills />
      <GithubStats />
      <Projects />
      <Gallery />
      <Certificates />
      <Contact />
    </main>

    <Footer />

    <style is:global>
      /* Pin spacers inserted by GSAP must be dark to prevent flash */
      .pin-spacer {
        background-color: #060a14 !important;
      }

      /* Hide scrollbar for Chrome, Safari and Opera */
      ::-webkit-scrollbar {
        display: none;
      }

      /* Hide scrollbar for IE, Edge and Firefox */
      * {
        -ms-overflow-style: none;
        scrollbar-width: none;
        cursor: none;
      }

      /* Restore cursor on mobile / touch devices */
      @media (pointer: coarse) {
        * {
          cursor: auto;
        }
      }

      @media (max-width: 768px) {
        * {
          cursor: auto;
        }
      }
    </style>
  </body>
</html>
